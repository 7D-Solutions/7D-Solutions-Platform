  "properties": {
    "event_id": {"type": "string"},
    "event_type": {"const": "auth.password_reset_requested"},
    "schema_version": {"const": "auth.password_reset_requested/v1"},
    "occurred_at": {"type": "string"},
    "producer": {"type": "string"},
    "tenant_id": {"type": "string"},
    "aggregate_type": {"const": "user"},
    "aggregate_id": {"type": "string"},
    "trace_id": {"type": "string"},
    "causation_id": {"type": ["string", "null"]},
    "data": {
      "type": "object",
      "required": ["user_id", "email", "raw_token", "expires_at", "correlation_id"],
      "properties": {
        "user_id": {"type": "string"},
        "email": {"type": "string"},
        "raw_token": {"type": "string"},
        "expires_at": {"type": "string"},
        "correlation_id": {"type": "string"}
      }
    }
  }
}
