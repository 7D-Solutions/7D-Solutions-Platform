          <mxGeometry height="60" width="170" x="490" y="555" as="geometry" />
        </mxCell>
        <mxCell id="t4-panel-data" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d3d;strokeColor=#555555;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;spacingRight=10;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Data Entities (Proposed)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#ffb300&quot;&gt;Inspection Module (new):&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:11px&quot;&gt;• InspectionPlan (item, revision)&lt;br&gt;• Characteristic (dimension, tolerance)&lt;br&gt;• SamplingRule (ISO 2859 AQL)&lt;br&gt;• InspectionRecord (results, disposition)&lt;br&gt;• InspectionMeasurement (actual values)&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#66bb6a&quot;&gt;Existing (consumed):&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:11px&quot;&gt;• ReceivingRecord (shipping-receiving-rs)&lt;br&gt;• StatusBucket (inventory-rs)&lt;br&gt;• CompetenceArtifact (workforce-rs)&lt;/font&gt;" vertex="1">
          <mxGeometry height="300" width="260" x="1200" y="100" as="geometry" />
        </mxCell>
        <mxCell id="t4-panel-events-pub" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d3d;strokeColor=#555555;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;spacingRight=10;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Events Published (Proposed)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:11px&quot;&gt;• inspection.record.created&lt;br&gt;• inspection.record.completed&lt;br&gt;• inspection.disposition.accepted&lt;br&gt;• inspection.disposition.rejected&lt;br&gt;• inspection.hold.placed&lt;br&gt;• inspection.hold.released&lt;/font&gt;" vertex="1">
          <mxGeometry height="170" width="260" x="1200" y="420" as="geometry" />
        </mxCell>
