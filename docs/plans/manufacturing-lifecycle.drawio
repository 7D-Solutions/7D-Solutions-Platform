        <mxCell id="t8-panel-data" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d3d;strokeColor=#555555;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;spacingRight=10;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Data Entities&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#66bb6a&quot;&gt;Shipping-Receiving:&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:11px&quot;&gt;• Shipment (lines, carrier, tracking)&lt;br&gt;• BillOfLading&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#66bb6a&quot;&gt;AR:&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:11px&quot;&gt;• Invoice (header + lines)&lt;br&gt;• CreditMemo&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#66bb6a&quot;&gt;Payments:&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:11px&quot;&gt;• Payment (amount, method, date)&lt;br&gt;• PaymentAllocation&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#66bb6a&quot;&gt;GL:&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:11px&quot;&gt;• JournalEntry (header + lines)&lt;br&gt;• Account (chart of accounts)&lt;br&gt;• FiscalPeriod&lt;/font&gt;" vertex="1">
          <mxGeometry height="370" width="260" x="1200" y="100" as="geometry" />
        </mxCell>
