<mxfile host="Electron" agent="Claude" version="29.5.2">
  <diagram id="qbo-phase1" name="QBO Integration — Phase 1: Visibility Layer">
    <mxGraphModel dx="1800" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="3300" pageHeight="2600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ═══ TITLE ═══ -->
        <mxCell id="title" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=#1a1a2e;strokeColor=none;rounded=1;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:24px&quot;&gt;&lt;b&gt;QuickBooks Online Integration — Phase 1&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:14px&quot;&gt;Our App = Visibility Layer — QBO Owns Money, Warehouse Owns Physical&lt;/font&gt;" vertex="1">
          <mxGeometry x="250" y="20" width="800" height="60" as="geometry" />
        </mxCell>

        <!-- ═══ LEGEND ═══ -->
