        <mxCell id="lane-pull" parent="1" style="shape=mxgraph.basic.rect;fillColor=#1a1a2e;strokeColor=#1565c0;strokeWidth=2;rounded=1;arcSize=4;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;html=1;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Data Flows IN — QBO to Our App&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:11px&quot;&gt;Pull customers and orders so people at the warehouse can see what needs to ship&lt;/font&gt;" vertex="1">
