          <mxGeometry x="1500" y="20" width="320" height="220" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" parent="1" style="text;html=1;align=left;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Who Owns What&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry x="1520" y="30" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-qbo" parent="1" style="rounded=1;fillColor=#1565c0;strokeColor=none;" value="" vertex="1">
          <mxGeometry x="1520" y="60" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-qbo-text" parent="1" style="text;html=1;align=left;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#AAAAAA&quot;&gt;&lt;b&gt;QuickBooks Online&lt;/b&gt; — customers, orders, money&lt;/font&gt;" vertex="1">
          <mxGeometry x="1550" y="60" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-wh" parent="1" style="rounded=1;fillColor=#2e7d32;strokeColor=none;" value="" vertex="1">
          <mxGeometry x="1520" y="90" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-wh-text" parent="1" style="text;html=1;align=left;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#AAAAAA&quot;&gt;&lt;b&gt;Warehouse&lt;/b&gt; — physical reality&lt;/font&gt;" vertex="1">
          <mxGeometry x="1550" y="90" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-app" parent="1" style="rounded=1;fillColor=#f57f17;strokeColor=none;" value="" vertex="1">
          <mxGeometry x="1520" y="120" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-app-text" parent="1" style="text;html=1;align=left;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#AAAAAA&quot;&gt;&lt;b&gt;Our App&lt;/b&gt; — visibility bridge (owns nothing)&lt;/font&gt;" vertex="1">
          <mxGeometry x="1550" y="120" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-user" parent="1" style="rounded=1;fillColor=#b71c1c;strokeColor=none;" value="" vertex="1">
          <mxGeometry x="1520" y="150" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-user-text" parent="1" style="text;html=1;align=left;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#AAAAAA&quot;&gt;&lt;b&gt;Person&lt;/b&gt; — manual action&lt;/font&gt;" vertex="1">
          <mxGeometry x="1550" y="150" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-note" parent="1" style="text;html=1;align=left;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#777777&quot; style=&quot;font-size:10px&quot;&gt;Phase 1: No inventory sync. No counts.&lt;br&gt;App is a read-only bridge + shipping entry point.&lt;/font&gt;" vertex="1">
          <mxGeometry x="1520" y="185" width="280" height="40" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- THE THREE PLAYERS                           -->
        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="players-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d3d;strokeColor=#555555;arcSize=6;align=center;verticalAlign=top;spacingTop=10;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:13px&quot;&gt;&lt;b&gt;The Three Players&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry x="40" y="110" width="1420" height="130" as="geometry" />
        </mxCell>

        <mxCell id="player-qbo" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565c0;strokeColor=#42a5f5;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:14px&quot;&gt;&lt;b&gt;QuickBooks Online&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#90caf9&quot;&gt;Source of truth for:&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;Customers, Invoices (orders),&lt;br&gt;Payments, Product catalog&lt;/font&gt;" vertex="1">
          <mxGeometry x="80" y="145" width="350" height="80" as="geometry" />
        </mxCell>

        <mxCell id="player-app" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Our App&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;The bridge where QBO + warehouse meet&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;Shows orders, captures shipments&lt;/font&gt;" vertex="1">
          <mxGeometry x="530" y="145" width="350" height="80" as="geometry" />
        </mxCell>

        <mxCell id="player-wh" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e7d32;strokeColor=#4caf50;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Warehouse&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#a5d6a7&quot;&gt;Source of truth for:&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot;&gt;What&#x27;s on the shelf, what shipped,&lt;br&gt;tracking numbers&lt;/font&gt;" vertex="1">
          <mxGeometry x="980" y="145" width="350" height="80" as="geometry" />
        </mxCell>

        <!-- Arrows between players -->
        <mxCell id="a-qbo-app" edge="1" parent="1" source="player-qbo" target="player-app" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#90caf9;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-app-wh" edge="1" parent="1" source="player-app" target="player-wh" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#a5d6a7;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- LANE 1: ONE-TIME SETUP                      -->
        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="lane-setup" parent="1" style="shape=mxgraph.basic.rect;fillColor=#1a1a2e;strokeColor=#f57f17;strokeWidth=2;rounded=1;arcSize=4;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;html=1;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:14px&quot;&gt;&lt;b&gt;One-Time Setup&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:11px&quot;&gt;Admin connects QBO to our app (browser required)&lt;/font&gt;" vertex="1">
          <mxGeometry x="40" y="280" width="1420" height="160" as="geometry" />
        </mxCell>

        <mxCell id="setup-click" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b71c1c;strokeColor=#e57373;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Admin Clicks&lt;br&gt;&quot;Connect to QuickBooks&quot;&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry x="80" y="335" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="setup-auth" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565c0;strokeColor=#42a5f5;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Intuit Login Screen&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#90caf9&quot;&gt;User authorizes access&lt;/font&gt;" vertex="1">
          <mxGeometry x="340" y="335" width="190" height="70" as="geometry" />
        </mxCell>

        <mxCell id="setup-tokens" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;App Stores Tokens&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;Encrypted, per tenant&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Must refresh before 100 days&lt;/font&gt;" vertex="1">
          <mxGeometry x="590" y="335" width="190" height="70" as="geometry" />
        </mxCell>

        <mxCell id="setup-pull" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Initial Data Pull&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;Customers + open invoices&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Populates the app tables&lt;/font&gt;" vertex="1">
          <mxGeometry x="840" y="335" width="190" height="70" as="geometry" />
        </mxCell>

        <mxCell id="setup-ready" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;App Ready&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;Dashboard shows orders&lt;/font&gt;" vertex="1">
          <mxGeometry x="1090" y="335" width="170" height="70" as="geometry" />
        </mxCell>

        <mxCell id="a-s1" edge="1" parent="1" source="setup-click" target="setup-auth" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-s2" edge="1" parent="1" source="setup-auth" target="setup-tokens" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-s3" edge="1" parent="1" source="setup-tokens" target="setup-pull" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-s4" edge="1" parent="1" source="setup-pull" target="setup-ready" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- LANE 2: PULL — QBO data into our app        -->
        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="lane-pull" parent="1" style="shape=mxgraph.basic.rect;fillColor=#1a1a2e;strokeColor=#1565c0;strokeWidth=2;rounded=1;arcSize=4;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;html=1;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Data Flows IN — QBO to Our App&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:11px&quot;&gt;Pull customers and orders so the warehouse can see what needs to ship&lt;/font&gt;" vertex="1">
          <mxGeometry x="40" y="480" width="1420" height="200" as="geometry" />
        </mxCell>

        <mxCell id="pull-change" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565c0;strokeColor=#42a5f5;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Something Changes&lt;br&gt;in QBO&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#90caf9&quot; style=&quot;font-size:10px&quot;&gt;New customer, new invoice,&lt;br&gt;invoice updated, payment received&lt;/font&gt;" vertex="1">
          <mxGeometry x="80" y="540" width="190" height="90" as="geometry" />
        </mxCell>

        <mxCell id="pull-webhook" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565c0;strokeColor=#42a5f5;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;QBO Sends Webhook&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#90caf9&quot; style=&quot;font-size:10px&quot;&gt;&quot;Invoice 456 changed&quot;&lt;br&gt;(ID only, no details)&lt;/font&gt;" vertex="1">
          <mxGeometry x="330" y="540" width="190" height="90" as="geometry" />
        </mxCell>

        <mxCell id="pull-fetch" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;App Fetches Details&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot; style=&quot;font-size:10px&quot;&gt;GET the full customer/invoice&lt;br&gt;from QBO API&lt;/font&gt;" vertex="1">
          <mxGeometry x="580" y="540" width="190" height="90" as="geometry" />
        </mxCell>

        <mxCell id="pull-update" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;App Updates Its Tables&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot; style=&quot;font-size:10px&quot;&gt;Customers table refreshed&lt;br&gt;Orders table refreshed&lt;br&gt;Payment status updated&lt;/font&gt;" vertex="1">
          <mxGeometry x="830" y="540" width="190" height="90" as="geometry" />
        </mxCell>

        <mxCell id="pull-visible" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e7d32;strokeColor=#4caf50;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Warehouse Sees It&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#a5d6a7&quot; style=&quot;font-size:10px&quot;&gt;&quot;Order #789 — 50 widgets&lt;br&gt;for Acme Corp — needs to ship&quot;&lt;/font&gt;" vertex="1">
          <mxGeometry x="1080" y="540" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Fallback poll -->
        <mxCell id="pull-poll" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;dashed=1;dashPattern=8 4;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Backup Poll&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot; style=&quot;font-size:10px&quot;&gt;Every 15 min — catches&lt;br&gt;missed webhooks&lt;/font&gt;" vertex="1">
          <mxGeometry x="330" y="645" width="140" height="55" as="geometry" />
        </mxCell>

        <mxCell id="a-p1" edge="1" parent="1" source="pull-change" target="pull-webhook" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-p2" edge="1" parent="1" source="pull-webhook" target="pull-fetch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-p3" edge="1" parent="1" source="pull-fetch" target="pull-update" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-p4" edge="1" parent="1" source="pull-update" target="pull-visible" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-poll" edge="1" parent="1" source="pull-poll" target="pull-fetch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=1;dashed=1;dashPattern=8 4;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="530" y="672" />
              <mxPoint x="530" y="585" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- LANE 3: PUSH — Shipping back to QBO         -->
        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="lane-push" parent="1" style="shape=mxgraph.basic.rect;fillColor=#1a1a2e;strokeColor=#2e7d32;strokeWidth=2;rounded=1;arcSize=4;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;html=1;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Data Flows OUT — Shipping Confirmation to QBO&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:11px&quot;&gt;Warehouse ships, enters tracking info, app pushes it back to QBO invoice&lt;/font&gt;" vertex="1">
          <mxGeometry x="40" y="720" width="1420" height="180" as="geometry" />
        </mxCell>

        <mxCell id="push-ships" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e7d32;strokeColor=#4caf50;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Warehouse Ships&lt;br&gt;the Order&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#a5d6a7&quot; style=&quot;font-size:10px&quot;&gt;Boxes packed, on the truck&lt;/font&gt;" vertex="1">
          <mxGeometry x="80" y="780" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="push-enter" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b71c1c;strokeColor=#e57373;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Worker Enters Tracking&lt;br&gt;in Our App&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ff8a80&quot; style=&quot;font-size:10px&quot;&gt;Carrier, tracking #, ship date&lt;/font&gt;" vertex="1">
          <mxGeometry x="320" y="780" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="push-save" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;App Saves Shipment&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot; style=&quot;font-size:10px&quot;&gt;Shipments table updated&lt;br&gt;Order marked &quot;shipped&quot;&lt;/font&gt;" vertex="1">
          <mxGeometry x="580" y="780" width="190" height="80" as="geometry" />
        </mxCell>

        <mxCell id="push-qbo" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565c0;strokeColor=#42a5f5;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;App Updates QBO Invoice&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#90caf9&quot; style=&quot;font-size:10px&quot;&gt;Sets ShipDate + TrackingNum&lt;br&gt;+ ShipMethod on the invoice&lt;/font&gt;" vertex="1">
          <mxGeometry x="830" y="780" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="push-done" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565c0;strokeColor=#42a5f5;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Bookkeeper Sees It&lt;br&gt;in QBO&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#90caf9&quot; style=&quot;font-size:10px&quot;&gt;Invoice has shipping info&lt;br&gt;Can collect payment&lt;/font&gt;" vertex="1">
          <mxGeometry x="1090" y="780" width="190" height="80" as="geometry" />
        </mxCell>

        <mxCell id="a-sh1" edge="1" parent="1" source="push-ships" target="push-enter" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-sh2" edge="1" parent="1" source="push-enter" target="push-save" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-sh3" edge="1" parent="1" source="push-save" target="push-qbo" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-sh4" edge="1" parent="1" source="push-qbo" target="push-done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- INFO PANELS (right side)                    -->
        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="info-scope" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d3d;strokeColor=#555555;arcSize=6;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;spacingRight=15;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Phase 1 Scope — What the App Shows&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot;&gt;&lt;b&gt;Customers Table&lt;/b&gt;&lt;br&gt;Pulled from QBO. Name, contact info.&lt;br&gt;Read-only — edits happen in QBO.&lt;br&gt;&lt;br&gt;&lt;b&gt;Orders Table&lt;/b&gt;&lt;br&gt;QBO invoices shown as orders.&lt;br&gt;What needs to ship, what already shipped.&lt;br&gt;Payment status from QBO (open/paid).&lt;br&gt;&lt;br&gt;&lt;b&gt;Shipments Table&lt;/b&gt;&lt;br&gt;Created in our app by warehouse.&lt;br&gt;Carrier, tracking #, date, line items.&lt;br&gt;This is the ONE thing we write.&lt;/font&gt;" vertex="1">
          <mxGeometry x="1500" y="280" width="320" height="310" as="geometry" />
        </mxCell>

        <mxCell id="info-not" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d3d;strokeColor=#b71c1c;arcSize=6;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;spacingRight=15;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;What Phase 1 Does NOT Do&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#ff8a80&quot;&gt;&#x2716; Inventory counts — no sync, no tracking&lt;br&gt;&#x2716; Create invoices — that stays in QBO&lt;br&gt;&#x2716; Process payments — that stays in QBO&lt;br&gt;&#x2716; Manage products — catalog comes from QBO&lt;br&gt;&#x2716; Tell warehouse what to do — just shows info&lt;br&gt;&#x2716; Replace any existing process&lt;/font&gt;" vertex="1">
          <mxGeometry x="1500" y="610" width="320" height="200" as="geometry" />
        </mxCell>

        <mxCell id="info-future" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d3d;strokeColor=#6a1b9a;arcSize=6;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;spacingRight=15;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Phase 2+ (Later)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#ce93d8&quot;&gt;&#x2192; App takes over inventory tracking&lt;br&gt;&#x2192; App manages pick/pack workflow&lt;br&gt;&#x2192; App creates invoices, pushes to QBO&lt;br&gt;&#x2192; App becomes the system of record&lt;br&gt;&#x2192; QBO becomes the bookkeeping backend&lt;/font&gt;" vertex="1">
          <mxGeometry x="1500" y="830" width="320" height="160" as="geometry" />
        </mxCell>

      </root>
