          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-sh4" edge="1" parent="1" source="push-qbo" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;" target="push-done">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="info-scope" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d3d;strokeColor=#555555;arcSize=6;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;spacingRight=15;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;What the App Shows (3 Tables)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot;&gt;&lt;b&gt;Customers&lt;/b&gt;&lt;br&gt;Pulled from QBO. Read-only.&lt;br&gt;Edits always happen in QBO.&lt;br&gt;&lt;br&gt;&lt;b&gt;Orders&lt;/b&gt;&lt;br&gt;QBO invoices displayed as orders.&lt;br&gt;Shows what needs to ship + payment status.&lt;br&gt;Read-only — created in QBO.&lt;br&gt;&lt;br&gt;&lt;b&gt;Shipments&lt;/b&gt;&lt;br&gt;The ONE thing our app writes.&lt;br&gt;Person enters carrier, tracking #, date.&lt;br&gt;Gets pushed back to QBO invoice.&lt;/font&gt;" vertex="1">
          <mxGeometry height="310" width="320" x="1500" y="240" as="geometry" />
        </mxCell>
        <mxCell id="info-not" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d3d;strokeColor=#b71c1c;arcSize=6;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;spacingRight=15;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;What Phase 1 Does NOT Do&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#ff8a80&quot;&gt;✖ Inventory counts — no sync, no tracking&lt;br&gt;✖ Create invoices — that stays in QBO&lt;br&gt;✖ Process payments — that stays in QBO&lt;br&gt;✖ Manage products — catalog from QBO&lt;br&gt;✖ Control warehouse operations&lt;br&gt;✖ Replace any existing process&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:10px&quot;&gt;The app doesn&#39;t own anything.&lt;br&gt;It&#39;s a window into QBO + a place to&lt;br&gt;record that something shipped.&lt;br&gt;&lt;br&gt;Note: QBO deducts inventory on Invoice creation.&lt;/font&gt;" vertex="1">
          <mxGeometry height="230" width="320" x="1500" y="570" as="geometry" />
        </mxCell>
        <mxCell id="info-future" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d3d;strokeColor=#6a1b9a;arcSize=6;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;spacingRight=15;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Phase 2+ (Later)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#ce93d8&quot;&gt;→ App takes over inventory tracking&lt;br&gt;→ App manages pick/pack workflow&lt;br&gt;→ App creates invoices, pushes to QBO&lt;br&gt;→ App becomes the system of record&lt;br&gt;→ QBO becomes the bookkeeping backend&lt;/font&gt;" vertex="1">
          <mxGeometry height="160" width="320" x="1500" y="820" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
