        <mxCell id="lane-push" parent="1" style="shape=mxgraph.basic.rect;fillColor=#1a1a2e;strokeColor=#f57f17;strokeWidth=2;rounded=1;arcSize=4;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;html=1;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Data Flows OUT — Shipping Confirmation to QBO&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:11px&quot;&gt;Someone at the warehouse enters tracking info in our app, app pushes it to QBO&lt;/font&gt;" vertex="1">
          <mxGeometry height="180" width="1420" x="40" y="720" as="geometry" />
        </mxCell>
