          <mxGeometry height="80" width="180" x="80" y="780" as="geometry" />
        </mxCell>
        <mxCell id="push-enter" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b71c1c;strokeColor=#e57373;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Person Enters Tracking&lt;br&gt;in Our App&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ff8a80&quot; style=&quot;font-size:10px&quot;&gt;Carrier, tracking #, ship date&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="200" x="320" y="780" as="geometry" />
        </mxCell>
        <mxCell id="push-save" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;App Saves Shipment&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot; style=&quot;font-size:10px&quot;&gt;Shipments table updated&lt;br&gt;Order marked &quot;shipped&quot; in app&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="190" x="580" y="780" as="geometry" />
        </mxCell>
        <mxCell id="push-qbo" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;App Updates QBO Invoice&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot; style=&quot;font-size:10px&quot;&gt;Sets ShipDate + TrackingNum + ShipMethod&lt;br&gt;Requires SyncToken + ?minorversion=75&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="200" x="830" y="780" as="geometry" />
        </mxCell>
