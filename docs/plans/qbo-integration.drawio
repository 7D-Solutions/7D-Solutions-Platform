        <mxCell id="legend-qbo-text" parent="1" style="text;html=1;align=left;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#AAAAAA&quot;&gt;QuickBooks Online (external)&lt;/font&gt;" vertex="1">
          <mxGeometry x="1550" y="60" width="220" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-platform" parent="1" style="rounded=1;fillColor=#2e7d32;strokeColor=none;" value="" vertex="1">
          <mxGeometry x="1520" y="90" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-platform-text" parent="1" style="text;html=1;align=left;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#AAAAAA&quot;&gt;7D Platform (existing modules)&lt;/font&gt;" vertex="1">
          <mxGeometry x="1550" y="90" width="220" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-new" parent="1" style="rounded=1;fillColor=#f57f17;strokeColor=none;" value="" vertex="1">
          <mxGeometry x="1520" y="120" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-new-text" parent="1" style="text;html=1;align=left;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#AAAAAA&quot;&gt;New integration code needed&lt;/font&gt;" vertex="1">
          <mxGeometry x="1550" y="120" width="220" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-event" parent="1" style="rounded=1;fillColor=#6a1b9a;strokeColor=none;" value="" vertex="1">
          <mxGeometry x="1520" y="150" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-event-text" parent="1" style="text;html=1;align=left;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#AAAAAA&quot;&gt;NATS event / async message&lt;/font&gt;" vertex="1">
          <mxGeometry x="1550" y="150" width="220" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-user" parent="1" style="rounded=1;fillColor=#b71c1c;strokeColor=none;" value="" vertex="1">
          <mxGeometry x="1520" y="180" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-user-text" parent="1" style="text;html=1;align=left;fillColor=none;strokeColor=none;" value="&lt;font color=&quot;#AAAAAA&quot;&gt;User / manual action&lt;/font&gt;" vertex="1">
          <mxGeometry x="1550" y="180" width="220" height="20" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- LANE 1: INITIAL SETUP (one-time)           -->
        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="lane-setup" parent="1" style="shape=mxgraph.basic.rect;fillColor=#1a1a2e;strokeColor=#f57f17;strokeWidth=2;rounded=1;arcSize=4;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;html=1;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:14px&quot;&gt;&lt;b&gt;One-Time Setup&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:11px&quot;&gt;Admin connects QBO to the platform&lt;/font&gt;" vertex="1">
          <mxGeometry x="40" y="110" width="1420" height="170" as="geometry" />
        </mxCell>

        <mxCell id="setup-start" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b71c1c;strokeColor=#e57373;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Admin clicks Connect&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;In platform settings page&lt;/font&gt;" vertex="1">
          <mxGeometry x="80" y="165" width="170" height="80" as="geometry" />
        </mxCell>

        <mxCell id="setup-oauth" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565c0;strokeColor=#42a5f5;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;QBO OAuth Screen&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#90caf9&quot;&gt;Intuit login + authorize&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;User grants accounting scope&lt;/font&gt;" vertex="1">
          <mxGeometry x="310" y="165" width="190" height="80" as="geometry" />
        </mxCell>

        <mxCell id="setup-callback" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Exchange Code for Tokens&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;New: OAuth callback handler&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Store access + refresh tokens&lt;/font&gt;" vertex="1">
          <mxGeometry x="560" y="165" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="setup-store" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Save Credentials&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;New: encrypted token store&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Realm ID + tokens per tenant&lt;/font&gt;" vertex="1">
          <mxGeometry x="820" y="165" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="setup-initial-sync" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Run Initial Sync&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;New: full item pull&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;All QBO inventory items imported&lt;/font&gt;" vertex="1">
          <mxGeometry x="1080" y="165" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- Setup arrows -->
        <mxCell id="a-setup-1" edge="1" parent="1" source="setup-start" target="setup-oauth" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-setup-2" edge="1" parent="1" source="setup-oauth" target="setup-callback" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-setup-3" edge="1" parent="1" source="setup-callback" target="setup-store" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-setup-4" edge="1" parent="1" source="setup-store" target="setup-initial-sync" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- LANE 2: INVENTORY SYNC (ongoing)            -->
        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="lane-inv-sync" parent="1" style="shape=mxgraph.basic.rect;fillColor=#1a1a2e;strokeColor=#2e7d32;strokeWidth=2;rounded=1;arcSize=4;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;html=1;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Inventory Sync — QBO to Platform&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:11px&quot;&gt;Keep platform inventory in sync with QuickBooks items&lt;/font&gt;" vertex="1">
          <mxGeometry x="40" y="320" width="1420" height="230" as="geometry" />
        </mxCell>

        <mxCell id="inv-webhook" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565c0;strokeColor=#42a5f5;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;QBO Sends Webhook&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#90caf9&quot;&gt;Item changed notification&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Entity name + ID only&lt;/font&gt;" vertex="1">
          <mxGeometry x="80" y="380" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="inv-verify" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Verify HMAC&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry x="320" y="385" width="130" height="70" as="geometry" />
        </mxCell>

        <mxCell id="inv-fetch" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Fetch Item from QBO&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;GET /item/{id}&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Name, SKU, qty, cost, price&lt;/font&gt;" vertex="1">
          <mxGeometry x="510" y="380" width="190" height="80" as="geometry" />
        </mxCell>

        <mxCell id="inv-map" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Map to Platform Format&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;New: field mapper&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;QBO Item  &#x2192;  7D inventory item&lt;/font&gt;" vertex="1">
          <mxGeometry x="760" y="380" width="190" height="80" as="geometry" />
        </mxCell>

        <mxCell id="inv-upsert" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e7d32;strokeColor=#4caf50;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Upsert in Inventory&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#a5d6a7&quot;&gt;Existing inventory module&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Create or update item + qty&lt;/font&gt;" vertex="1">
          <mxGeometry x="1010" y="380" width="190" height="80" as="geometry" />
        </mxCell>

        <mxCell id="inv-event" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6a1b9a;strokeColor=#ab47bc;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Publish Sync Event&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ce93d8&quot;&gt;NATS: inventory.qbo.synced&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Other modules can react&lt;/font&gt;" vertex="1">
          <mxGeometry x="1010" y="475" width="190" height="60" as="geometry" />
        </mxCell>

        <!-- Fallback: scheduled CDC poll -->
        <mxCell id="inv-cdc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;dashed=1;dashPattern=8 4;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Scheduled CDC Poll&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;Fallback: every 15 min&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Catches missed webhooks&lt;/font&gt;" vertex="1">
          <mxGeometry x="80" y="475" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Inv sync arrows -->
        <mxCell id="a-inv-1" edge="1" parent="1" source="inv-webhook" target="inv-verify" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-inv-2" edge="1" parent="1" source="inv-verify" target="inv-fetch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-inv-3" edge="1" parent="1" source="inv-fetch" target="inv-map" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-inv-4" edge="1" parent="1" source="inv-map" target="inv-upsert" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-inv-5" edge="1" parent="1" source="inv-upsert" target="inv-event" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6a1b9a;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-inv-cdc" edge="1" parent="1" source="inv-cdc" target="inv-fetch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=1;dashed=1;dashPattern=8 4;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="170" y="460" />
              <mxPoint x="480" y="460" />
              <mxPoint x="480" y="420" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- LANE 3: SHIPPING NOTIFICATION (platform to QBO) -->
        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="lane-ship" parent="1" style="shape=mxgraph.basic.rect;fillColor=#1a1a2e;strokeColor=#1565c0;strokeWidth=2;rounded=1;arcSize=4;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;html=1;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Ship Notification — Platform to QBO&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:11px&quot;&gt;When a shipment is confirmed, update the QBO invoice&lt;/font&gt;" vertex="1">
          <mxGeometry x="40" y="590" width="1420" height="180" as="geometry" />
        </mxCell>

        <mxCell id="ship-confirm" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e7d32;strokeColor=#4caf50;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Shipment Confirmed&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#a5d6a7&quot;&gt;Shipping-receiving module&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Carrier, tracking #, ship date&lt;/font&gt;" vertex="1">
          <mxGeometry x="80" y="650" width="190" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ship-event" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6a1b9a;strokeColor=#ab47bc;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;NATS Event Published&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ce93d8&quot;&gt;shipping.shipment.confirmed&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Includes invoice ref + tracking&lt;/font&gt;" vertex="1">
          <mxGeometry x="330" y="650" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ship-consumer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;QBO Shipping Consumer&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;New: NATS consumer&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Picks up shipment events&lt;/font&gt;" vertex="1">
          <mxGeometry x="590" y="650" width="190" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ship-lookup" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Find QBO Invoice&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;New: cross-reference lookup&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Match platform order &#x2192; QBO invoice&lt;/font&gt;" vertex="1">
          <mxGeometry x="840" y="650" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ship-update" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565c0;strokeColor=#42a5f5;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Update QBO Invoice&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#90caf9&quot;&gt;Sparse update to Intuit API&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Set ShipDate + TrackingNum&lt;/font&gt;" vertex="1">
          <mxGeometry x="1100" y="650" width="190" height="80" as="geometry" />
        </mxCell>

        <!-- Ship arrows -->
        <mxCell id="a-ship-1" edge="1" parent="1" source="ship-confirm" target="ship-event" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6a1b9a;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-ship-2" edge="1" parent="1" source="ship-event" target="ship-consumer" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-ship-3" edge="1" parent="1" source="ship-consumer" target="ship-lookup" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-ship-4" edge="1" parent="1" source="ship-lookup" target="ship-update" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- LANE 4: TOKEN REFRESH (background)          -->
        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="lane-token" parent="1" style="shape=mxgraph.basic.rect;fillColor=#1a1a2e;strokeColor=#6a1b9a;strokeWidth=2;rounded=1;arcSize=4;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;html=1;" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Token Lifecycle (Background)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot; style=&quot;font-size:11px&quot;&gt;Access tokens expire every 60 min — refresh tokens every 100 days&lt;/font&gt;" vertex="1">
          <mxGeometry x="40" y="810" width="1420" height="150" as="geometry" />
        </mxCell>

        <mxCell id="token-check" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Token About to Expire?&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;Check before every API call&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;If &lt; 5 min remaining&lt;/font&gt;" vertex="1">
          <mxGeometry x="80" y="870" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="token-refresh" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565c0;strokeColor=#42a5f5;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Call Intuit Token Endpoint&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#90caf9&quot;&gt;POST /oauth2/v1/tokens/bearer&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Send current refresh token&lt;/font&gt;" vertex="1">
          <mxGeometry x="370" y="870" width="220" height="70" as="geometry" />
        </mxCell>

        <mxCell id="token-persist" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Persist NEW Tokens&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot;&gt;Old refresh token is now dead&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Must save immediately or lose access&lt;/font&gt;" vertex="1">
          <mxGeometry x="680" y="870" width="210" height="70" as="geometry" />
        </mxCell>

        <mxCell id="token-alert" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b71c1c;strokeColor=#e57373;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Alert if 90+ Days&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ff8a80&quot;&gt;Refresh token nearing death&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#CCCCCC&quot; style=&quot;font-size:10px&quot;&gt;Admin must re-authorize at 100 days&lt;/font&gt;" vertex="1">
          <mxGeometry x="980" y="870" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- Token arrows -->
        <mxCell id="a-token-1" edge="1" parent="1" source="token-check" target="token-refresh" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-token-2" edge="1" parent="1" source="token-refresh" target="token-persist" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-token-3" edge="1" parent="1" source="token-persist" target="token-alert" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- INFO PANEL (right side)                     -->
        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="info-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d3d;strokeColor=#555555;arcSize=6;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;spacingRight=15;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;Key Facts&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot;&gt;&lt;b&gt;Auth:&lt;/b&gt; OAuth 2.0 Authorization Code&lt;br&gt;Access token: 60 min&lt;br&gt;Refresh token: 100 days&lt;br&gt;No headless flow — human must authorize&lt;br&gt;&lt;br&gt;&lt;b&gt;Rate Limits:&lt;/b&gt;&lt;br&gt;500 requests/min per company&lt;br&gt;10 concurrent requests max&lt;br&gt;&lt;br&gt;&lt;b&gt;Pricing (reads are metered):&lt;/b&gt;&lt;br&gt;Free tier: 500K reads/mo&lt;br&gt;Silver ($300/mo): 1M reads/mo&lt;br&gt;Writes: always free &amp;amp; unlimited&lt;br&gt;&lt;br&gt;&lt;b&gt;Gotchas:&lt;/b&gt;&lt;br&gt;&#x2022; Always pass ?minorversion=75&lt;br&gt;&#x2022; Webhooks are best-effort, up to 5 min delay&lt;br&gt;&#x2022; Webhooks carry ID only — must GET the data&lt;br&gt;&#x2022; SyncToken = optimistic locking on updates&lt;br&gt;&#x2022; No Shipment entity — shipping lives on Invoice&lt;br&gt;&#x2022; CloudEvents migration deadline: May 2026&lt;/font&gt;" vertex="1">
          <mxGeometry x="1500" y="250" width="300" height="460" as="geometry" />
        </mxCell>

        <mxCell id="info-box-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d2d3d;strokeColor=#555555;arcSize=6;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;spacingRight=15;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;What We Build (amber boxes)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#AAAAAA&quot;&gt;1. OAuth callback handler&lt;br&gt;2. Encrypted token store (per tenant)&lt;br&gt;3. Token refresh background job&lt;br&gt;4. Webhook receiver + HMAC verifier&lt;br&gt;5. QBO REST client (reqwest, no SDK)&lt;br&gt;6. Item field mapper (QBO &#x2192; platform)&lt;br&gt;7. CDC fallback poller (every 15 min)&lt;br&gt;8. Shipping NATS consumer&lt;br&gt;9. Invoice cross-reference table&lt;br&gt;10. Sparse invoice updater&lt;br&gt;&lt;br&gt;&lt;b&gt;Fits in:&lt;/b&gt; integrations module&lt;br&gt;(already has outbound webhooks + events)&lt;/font&gt;" vertex="1">
          <mxGeometry x="1500" y="730" width="300" height="290" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
