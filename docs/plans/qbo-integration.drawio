        </mxCell>
        <mxCell id="pull-fetch" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f57f17;strokeColor=#ffb74d;arcSize=12;" value="&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;App Fetches Details&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ffe082&quot; style=&quot;font-size:10px&quot;&gt;GET full customer/invoice from QBO API&lt;br&gt;Always use ?minorversion=75&lt;/font&gt;" vertex="1">
