        <mxCell id="a-poll" edge="1" parent="1" source="pull-poll" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#888888;strokeWidth=1;dashed=1;dashPattern=8 4;" target="pull-fetch">
