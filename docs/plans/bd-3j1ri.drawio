        <mxCell id="key-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1c2233;strokeColor=#455A64;arcSize=8;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" value="&lt;font color=&quot;#ECEFF1&quot;&gt;&lt;b&gt;Key Invariants&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#A5D6A7&quot; style=&quot;font-size:10px&quot;&gt;No new tables&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#A5D6A7&quot; style=&quot;font-size:10px&quot;&gt;No cross-module DB reads&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#A5D6A7&quot; style=&quot;font-size:10px&quot;&gt;No new crates&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#FFB74D&quot; style=&quot;font-size:10px&quot;&gt;Backward compat: unavailable&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#FFB74D&quot; style=&quot;font-size:10px&quot;&gt; modules don&apos;t fail overall_healthy&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#FF8A80&quot; style=&quot;font-size:10px&quot;&gt;DLQ &gt; 0 or outbox &gt; 0 → unhealthy&lt;/font&gt;" vertex="1">
