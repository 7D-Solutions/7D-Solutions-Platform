# ============================================================
# TCP UI — local environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.
# ============================================================

# ── Auth ─────────────────────────────────────────────────────
# Secret used by jose to verify staff JWTs.
# Must match the JWT_SECRET used by identity-auth.
JWT_SECRET=replace-with-your-jwt-secret

# ── Backend service URLs (server-side only) ──────────────────
# identity-auth service (for BFF /api/auth/* routes)
IDENTITY_AUTH_BASE_URL=http://localhost:8080

# tenant-registry service
TENANT_REGISTRY_BASE_URL=http://localhost:8095

# ── Playwright smoke tests ────────────────────────────────────
# Staff account credentials for Playwright loginAsStaff() fixture.
# Must have the platform_admin role in identity-auth.
TEST_STAFF_EMAIL=admin@7dsolutions.com
TEST_STAFF_PASSWORD=replace-with-test-password

# ── Optional ─────────────────────────────────────────────────
# Override the app base URL used by Playwright (default: http://localhost:3000)
# BASE_URL=http://localhost:3000

# Set to 'true' to suppress the beforeunload warning in tests
# NEXT_PUBLIC_DISABLE_UNLOAD_WARNING=true
