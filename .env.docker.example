# 7D Solutions Platform - Docker Environment Template
# Copy this file to .env.docker and replace every CHANGEME_ value before bringing services up.
# Any service that starts with an unreplaced CHANGEME_ value should fail fast.

# =========================
# AUTH DATABASE
# =========================
AUTH_POSTGRES_DB=auth_db
AUTH_POSTGRES_USER=auth_user
AUTH_POSTGRES_PASSWORD=CHANGEME_AUTH_POSTGRES_PASSWORD

# =========================
# REFERENCE DATABASE
# =========================
REFERENCE_POSTGRES_DB=reference_db
REFERENCE_POSTGRES_USER=ref_user
REFERENCE_POSTGRES_PASSWORD=CHANGEME_REFERENCE_POSTGRES_PASSWORD

# =========================
# AR DATABASE
# =========================
AR_POSTGRES_DB=ar_db
AR_POSTGRES_USER=ar_user
AR_POSTGRES_PASSWORD=CHANGEME_AR_POSTGRES_PASSWORD

# =========================
# SUBSCRIPTIONS DATABASE
# =========================
SUBSCRIPTIONS_POSTGRES_DB=subscriptions_db
SUBSCRIPTIONS_POSTGRES_USER=subscriptions_user
SUBSCRIPTIONS_POSTGRES_PASSWORD=CHANGEME_SUBSCRIPTIONS_POSTGRES_PASSWORD

# =========================
# PAYMENTS DATABASE
# =========================
PAYMENTS_POSTGRES_DB=payments_db
PAYMENTS_POSTGRES_USER=payments_user
PAYMENTS_POSTGRES_PASSWORD=CHANGEME_PAYMENTS_POSTGRES_PASSWORD

# =========================
# NOTIFICATIONS DATABASE
# =========================
NOTIFICATIONS_POSTGRES_DB=notifications_db
NOTIFICATIONS_POSTGRES_USER=notifications_user
NOTIFICATIONS_POSTGRES_PASSWORD=CHANGEME_NOTIFICATIONS_POSTGRES_PASSWORD

# =========================
# PROJECTIONS DATABASE
# =========================
PROJECTIONS_POSTGRES_DB=projections_db
PROJECTIONS_POSTGRES_USER=projections_user
PROJECTIONS_POSTGRES_PASSWORD=CHANGEME_PROJECTIONS_POSTGRES_PASSWORD

# =========================
# AUDIT DATABASE
# =========================
AUDIT_POSTGRES_DB=audit_db
AUDIT_POSTGRES_USER=audit_user
AUDIT_POSTGRES_PASSWORD=CHANGEME_AUDIT_POSTGRES_PASSWORD

# =========================
# TENANT REGISTRY DATABASE
# =========================
TENANT_REGISTRY_POSTGRES_DB=tenant_registry_db
TENANT_REGISTRY_POSTGRES_USER=tenant_registry_user
TENANT_REGISTRY_POSTGRES_PASSWORD=CHANGEME_TENANT_REGISTRY_POSTGRES_PASSWORD

# =========================
# CRM PIPELINE DATABASE
# =========================
CRM_PIPELINE_POSTGRES_DB=crm_pipeline_db
CRM_PIPELINE_POSTGRES_USER=crm_pipeline_user
CRM_PIPELINE_POSTGRES_PASSWORD=CHANGEME_CRM_PIPELINE_POSTGRES_PASSWORD

# =========================
# CUSTOMER COMPLAINTS DATABASE
# =========================
CC_POSTGRES_DB=cc_db
CC_POSTGRES_USER=cc_user
CC_POSTGRES_PASSWORD=CHANGEME_CC_POSTGRES_PASSWORD

# =========================
# AUTH SERVICE
# =========================
JWT_PRIVATE_KEY_PEM=your_private_key_here
JWT_PUBLIC_KEY_PEM=your_public_key_here
JWT_KID=auth-key-1
BOOTSTRAP_TOKEN=your_bootstrap_token_here

# =========================
# LOGGING
# =========================
RUST_LOG=info
