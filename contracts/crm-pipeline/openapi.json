  "components": {
    "schemas": {
      "Lead": {
        "type": "object",
        "required": ["id", "tenant_id", "lead_number", "title", "status", "created_at", "updated_at"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "tenant_id": { "type": "string" },
          "lead_number": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "string" },
          "source": { "type": ["string", "null"] },
          "party_id": { "type": ["string", "null"], "format": "uuid" },
          "party_contact_id": { "type": ["string", "null"], "format": "uuid" },
          "assigned_user_id": { "type": ["string", "null"], "format": "uuid" },
          "estimated_value_cents": { "type": ["integer", "null"] },
          "currency_code": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] },
          "disqualify_reason": { "type": ["string", "null"] },
          "converted_opportunity_id": { "type": ["string", "null"], "format": "uuid" },
          "converted_at": { "type": ["string", "null"], "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateLeadRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "source": { "type": ["string", "null"] },
          "party_id": { "type": ["string", "null"], "format": "uuid" },
          "party_contact_id": { "type": ["string", "null"], "format": "uuid" },
          "assigned_user_id": { "type": ["string", "null"], "format": "uuid" },
          "estimated_value_cents": { "type": ["integer", "null"] },
          "currency_code": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      },
      "UpdateLeadRequest": {
        "type": "object",
        "properties": {
          "title": { "type": ["string", "null"] },
          "source": { "type": ["string", "null"] },
          "party_id": { "type": ["string", "null"], "format": "uuid" },
          "party_contact_id": { "type": ["string", "null"], "format": "uuid" },
          "assigned_user_id": { "type": ["string", "null"], "format": "uuid" },
          "estimated_value_cents": { "type": ["integer", "null"] },
          "currency_code": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      },
      "ConvertLeadRequest": {
        "type": "object",
        "required": ["party_id"],
        "properties": {
          "party_id": { "type": "string", "format": "uuid" },
          "opportunity_title": { "type": ["string", "null"] }
        }
      },
      "ConvertLeadResponse": {
        "type": "object",
        "required": ["lead_id", "opportunity_id"],
        "properties": {
          "lead_id": { "type": "string", "format": "uuid" },
          "opportunity_id": { "type": "string", "format": "uuid" }
        }
      },
      "DisqualifyLeadRequest": {
        "type": "object",
        "required": ["reason"],
        "properties": {
          "reason": { "type": "string" }
        }
      },
      "Opportunity": {
        "type": "object",
        "required": ["id", "tenant_id", "opp_number", "title", "stage_code", "created_at", "updated_at"],
        "properties": {
