{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/integrations-webhook-routed.v1.json",
  "title": "webhook.routed",
  "description": "Event emitted after an inbound webhook has been translated to a domain event",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "const": "webhook.routed" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "source_module": { "type": "string", "const": "integrations" },
    "source_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "schema_version": { "type": "string", "minLength": 1 },
    "replay_safe": { "type": "boolean" },
    "mutation_class": { "type": "string", "const": "LIFECYCLE" },
    "correlation_id": { "type": "string" },
    "causation_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": [
        "ingest_id",
        "system",
        "domain_event_type",
        "outbox_event_id",
        "routed_at"
      ],
      "properties": {
        "ingest_id": { "type": "integer" },
        "system": { "type": "string", "minLength": 1 },
        "source_event_type": { "type": ["string", "null"] },
        "domain_event_type": { "type": "string", "minLength": 1 },
        "outbox_event_id": { "type": "string", "format": "uuid" },
        "routed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
