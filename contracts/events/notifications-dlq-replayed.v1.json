{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/notifications-dlq-replayed.v1.json",
  "title": "notifications.dlq.replayed",
  "type": "object",
  "required": ["event_id", "event_type", "occurred_at", "tenant_id", "source_module", "source_version", "schema_version", "replay_safe", "mutation_class", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "const": "notifications.dlq.replayed" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "source_module": { "type": "string", "const": "notifications" },
    "source_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "schema_version": { "type": "string", "minLength": 1 },
    "replay_safe": { "type": "boolean" },
    "mutation_class": { "type": "string", "const": "LIFECYCLE" },
    "correlation_id": { "type": "string" },
    "causation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["notification_id", "action", "previous_status", "new_status"],
      "properties": {
        "notification_id": { "type": "string", "format": "uuid" },
        "action": { "type": "string", "const": "replay" },
        "previous_status": { "type": "string", "const": "dead_lettered" },
        "new_status": { "type": "string", "const": "pending" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
