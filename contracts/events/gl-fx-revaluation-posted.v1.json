{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/gl-fx-revaluation-posted.v1.json",
  "title": "gl.fx_revaluation_posted",
  "description": "Event emitted when unrealized FX revaluation is posted to GL",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "const": "gl.fx_revaluation_posted" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "source_module": { "type": "string", "const": "gl" },
    "source_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "schema_version": { "type": "string", "minLength": 1 },
    "replay_safe": { "type": "boolean" },
    "mutation_class": { "type": "string", "const": "DATA_MUTATION" },
    "correlation_id": { "type": "string" },
    "causation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": [
        "revaluation_id",
        "tenant_id",
        "period",
        "transaction_currency",
        "reporting_currency",
        "rate_used",
        "original_amount_minor",
        "revalued_amount_minor",
        "unrealized_gain_loss_minor",
        "gain_loss_account",
        "balance_account",
        "revaluation_date",
        "auto_reverse"
      ],
      "properties": {
        "revaluation_id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "minLength": 1 },
        "period": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
        "transaction_currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "reporting_currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "rate_used": { "type": "number", "exclusiveMinimum": 0 },
        "original_amount_minor": { "type": "integer" },
        "revalued_amount_minor": { "type": "integer" },
        "unrealized_gain_loss_minor": { "type": "integer" },
        "gain_loss_account": { "type": "string", "minLength": 1 },
        "balance_account": { "type": "string", "minLength": 1 },
        "journal_entry_id": { "type": ["string", "null"], "format": "uuid" },
        "revaluation_date": { "type": "string", "format": "date" },
        "auto_reverse": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
