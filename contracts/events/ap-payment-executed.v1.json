{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/ap-payment-executed.v1.json",
  "title": "ap.payment_executed",
  "description": "Event emitted when a single vendor payment is executed as part of a payment run",
  "type": "object",
  "required": [
    "event_id",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (idempotency key)"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was generated"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant identifier for multi-tenant isolation"
    },
    "source_module": {
      "type": "string",
      "const": "ap",
      "description": "Module that generated the event"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the source module"
    },
    "correlation_id": {
      "type": "string",
      "description": "Links related events in a business transaction"
    },
    "causation_id": {
      "type": "string",
      "description": "Links this event to the command/event that caused it"
    },
    "payload": {
      "type": "object",
      "required": [
        "payment_id",
        "run_id",
        "tenant_id",
        "vendor_id",
        "bill_ids",
        "amount_minor",
        "currency",
        "payment_method",
        "executed_at"
      ],
      "properties": {
        "payment_id": {
          "type": "string",
          "format": "uuid",
          "description": "Payment identifier"
        },
        "run_id": {
          "type": "string",
          "format": "uuid",
          "description": "Payment run this payment belongs to"
        },
        "tenant_id": {
          "type": "string",
          "description": "Tenant identifier"
        },
        "vendor_id": {
          "type": "string",
          "format": "uuid",
          "description": "Vendor being paid"
        },
        "bill_ids": {
          "type": "array",
          "items": { "type": "string", "format": "uuid" },
          "minItems": 1,
          "description": "Bills settled by this payment"
        },
        "amount_minor": {
          "type": "integer",
          "description": "Amount paid in minor currency units"
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3,
          "pattern": "^[A-Z]{3}$",
          "description": "ISO 4217 currency code"
        },
        "payment_method": {
          "type": "string",
          "description": "Payment method used (e.g. ach, wire, check)"
        },
        "bank_reference": {
          "type": ["string", "null"],
          "description": "Bank or payment processor reference number"
        },
        "bank_account_last4": {
          "type": ["string", "null"],
          "description": "Bank account last 4 digits (for audit)"
        },
        "executed_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of execution"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
