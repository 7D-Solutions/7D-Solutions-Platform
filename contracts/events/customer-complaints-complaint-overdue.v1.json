{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/customer-complaints-complaint-overdue.v1.json",
  "title": "customer_complaints.complaint_overdue",
  "description": "Event emitted once per complaint when its due date passes without closure",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "const": "customer_complaints.complaint_overdue"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "source_module": {
      "type": "string",
      "const": "customer-complaints"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "replay_safe": {
      "type": "boolean"
    },
    "mutation_class": {
      "type": "string",
      "enum": [
        "DATA_MUTATION",
        "REVERSAL",
        "CORRECTION",
        "SIDE_EFFECT",
        "QUERY",
        "LIFECYCLE",
        "ADMINISTRATIVE"
      ]
    },
    "correlation_id": {
      "type": "string"
    },
    "causation_id": {
      "type": "string"
    },
    "payload": {
      "type": "object",
      "required": [
        "complaint_id",
        "tenant_id",
        "due_date",
        "days_overdue"
      ],
      "properties": {
        "complaint_id": {
          "type": "string",
          "format": "uuid",
          "description": "Complaint identifier"
        },
        "tenant_id": {
          "type": "string",
          "description": "Tenant identifier"
        },
        "assigned_to": {
          "type": ["string", "null"],
          "description": "Current assignee (null if unassigned)"
        },
        "due_date": {
          "type": "string",
          "format": "date-time",
          "description": "The complaint's due date"
        },
        "days_overdue": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of days past the due date"
        },
        "severity": {
          "type": ["string", "null"],
          "description": "Complaint severity label"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
