{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/ap-po-created.v1.json",
  "title": "ap.po_created",
  "description": "Event emitted when a purchase order is created",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (idempotency key)"
    },
    "event_type": {
      "type": "string",
      "const": "ap.po_created",
      "description": "Event type following entity.action convention"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was generated"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant identifier for multi-tenant isolation"
    },
    "source_module": {
      "type": "string",
      "const": "ap",
      "description": "Module that generated the event"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the source module"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "Schema version of the payload"
    },
    "replay_safe": {
      "type": "boolean",
      "description": "Whether the event can be safely replayed"
    },
    "mutation_class": {
      "type": "string",
      "enum": [
        "DATA_MUTATION",
        "REVERSAL",
        "CORRECTION",
        "SIDE_EFFECT",
        "QUERY",
        "LIFECYCLE",
        "ADMINISTRATIVE"
      ],
      "description": "Classification of the mutation"
    },
    "correlation_id": {
      "type": "string",
      "description": "Links related events in a business transaction"
    },
    "causation_id": {
      "type": "string",
      "description": "Links this event to the command/event that caused it"
    },
    "payload": {
      "type": "object",
      "required": [
        "po_id",
        "tenant_id",
        "vendor_id",
        "po_number",
        "currency",
        "lines",
        "total_minor",
        "created_by",
        "created_at"
      ],
      "properties": {
        "po_id": {
          "type": "string",
          "format": "uuid",
          "description": "Purchase order identifier"
        },
        "tenant_id": {
          "type": "string",
          "description": "Tenant identifier"
        },
        "vendor_id": {
          "type": "string",
          "format": "uuid",
          "description": "Vendor identifier"
        },
        "po_number": {
          "type": "string",
          "description": "Human-readable PO number"
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3,
          "pattern": "^[A-Z]{3}$",
          "description": "ISO 4217 currency code"
        },
        "lines": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "line_id",
              "description",
              "quantity",
              "unit_of_measure",
              "unit_price_minor",
              "gl_account_code"
            ],
            "properties": {
              "line_id": {
                "type": "string",
                "format": "uuid"
              },
              "description": {
                "type": "string"
              },
              "quantity": {
                "type": "number"
              },
              "unit_of_measure": {
                "type": "string"
              },
              "unit_price_minor": {
                "type": "integer"
              },
              "gl_account_code": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "minItems": 1
        },
        "total_minor": {
          "type": "integer",
          "description": "Total PO value in minor currency units"
        },
        "created_by": {
          "type": "string",
          "description": "Actor who created the PO"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of creation"
        },
        "expected_delivery_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "description": "Expected delivery date"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
