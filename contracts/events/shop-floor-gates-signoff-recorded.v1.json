{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/shop-floor-gates-signoff-recorded.v1.json",
  "title": "shop_floor_gates.signoff_recorded",
  "description": "Event emitted when an attestation signoff is recorded on a shop-floor entity",
  "type": "object",
  "required": ["event_id", "event_type", "occurred_at", "tenant_id", "source_module", "source_version", "schema_version", "replay_safe", "mutation_class", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "const": "shop_floor_gates.signoff_recorded" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string" },
    "source_module": { "type": "string", "const": "shop-floor-gates" },
    "source_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "schema_version": { "type": "string", "minLength": 1 },
    "replay_safe": { "type": "boolean" },
    "mutation_class": { "type": "string", "enum": ["DATA_MUTATION", "REVERSAL", "CORRECTION", "SIDE_EFFECT", "QUERY", "LIFECYCLE", "ADMINISTRATIVE"] },
    "correlation_id": { "type": "string" },
    "causation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["tenant_id", "signoff_id", "signoff_number", "entity_type", "entity_id", "role", "signed_by", "signed_at"],
      "properties": {
        "tenant_id": { "type": "string" },
        "signoff_id": { "type": "string", "format": "uuid" },
        "signoff_number": { "type": "string" },
        "entity_type": { "type": "string", "enum": ["work_order", "operation", "operation_handoff", "operation_start_verification", "traveler_hold"] },
        "entity_id": { "type": "string", "format": "uuid" },
        "role": { "type": "string" },
        "signed_by": { "type": "string", "format": "uuid" },
        "signed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
