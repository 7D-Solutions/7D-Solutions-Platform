{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/doc-mgmt-document-distribution-requested.v1.json",
  "title": "document.distribution.requested",
  "description": "Event emitted when a released document distribution is requested",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "const": "document.distribution.requested"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "source_module": {
      "type": "string",
      "const": "doc_mgmt"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "replay_safe": {
      "type": "boolean"
    },
    "mutation_class": {
      "type": "string",
      "enum": [
        "DATA_MUTATION",
        "REVERSAL",
        "CORRECTION",
        "SIDE_EFFECT",
        "QUERY",
        "LIFECYCLE",
        "ADMINISTRATIVE"
      ]
    },
    "correlation_id": {
      "type": "string"
    },
    "causation_id": {
      "type": "string"
    },
    "payload": {
      "type": "object",
      "required": [
        "distribution_id",
        "document_id",
        "doc_number",
        "recipient_ref",
        "channel",
        "template_key",
        "payload_json"
      ],
      "properties": {
        "distribution_id": {
          "type": "string",
          "format": "uuid"
        },
        "document_id": {
          "type": "string",
          "format": "uuid"
        },
        "revision_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "doc_number": {
          "type": "string",
          "minLength": 1
        },
        "recipient_ref": {
          "type": "string",
          "minLength": 1
        },
        "channel": {
          "type": "string",
          "minLength": 1
        },
        "template_key": {
          "type": "string",
          "minLength": 1
        },
        "payload_json": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
