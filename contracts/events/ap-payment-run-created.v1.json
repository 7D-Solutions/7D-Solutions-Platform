{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/ap-payment-run-created.v1.json",
  "title": "ap.payment_run_created",
  "description": "Event emitted when a batch of vendor payments is queued for execution",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (idempotency key)"
    },
    "event_type": {
      "type": "string",
      "const": "ap.payment_run_created",
      "description": "Event type following entity.action convention"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was generated"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant identifier for multi-tenant isolation"
    },
    "source_module": {
      "type": "string",
      "const": "ap",
      "description": "Module that generated the event"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the source module"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "Schema version of the payload"
    },
    "replay_safe": {
      "type": "boolean",
      "description": "Whether the event can be safely replayed"
    },
    "mutation_class": {
      "type": "string",
      "enum": [
        "DATA_MUTATION",
        "REVERSAL",
        "CORRECTION",
        "SIDE_EFFECT",
        "QUERY",
        "LIFECYCLE",
        "ADMINISTRATIVE"
      ],
      "description": "Classification of the mutation"
    },
    "correlation_id": {
      "type": "string",
      "description": "Links related events in a business transaction"
    },
    "causation_id": {
      "type": "string",
      "description": "Links this event to the command/event that caused it"
    },
    "payload": {
      "type": "object",
      "required": [
        "run_id",
        "tenant_id",
        "items",
        "total_minor",
        "currency",
        "scheduled_date",
        "payment_method",
        "created_by",
        "created_at"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "format": "uuid",
          "description": "Payment run identifier"
        },
        "tenant_id": {
          "type": "string",
          "description": "Tenant identifier"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "vendor_id",
              "bill_ids",
              "amount_minor",
              "currency"
            ],
            "properties": {
              "vendor_id": {
                "type": "string",
                "format": "uuid"
              },
              "bill_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uuid"
                },
                "minItems": 1
              },
              "amount_minor": {
                "type": "integer"
              },
              "currency": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "minItems": 1
        },
        "total_minor": {
          "type": "integer",
          "description": "Total across all items in minor currency units"
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3,
          "pattern": "^[A-Z]{3}$",
          "description": "ISO 4217 currency code"
        },
        "scheduled_date": {
          "type": "string",
          "format": "date-time",
          "description": "Scheduled execution date"
        },
        "payment_method": {
          "type": "string",
          "description": "Payment method for all items (e.g. ach, wire, check)"
        },
        "created_by": {
          "type": "string",
          "description": "Actor who created the payment run"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of creation"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
