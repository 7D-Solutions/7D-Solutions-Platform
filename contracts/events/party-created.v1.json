{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/party-created.v1.json",
  "title": "party.created",
  "description": "Event emitted when a new party (company or individual) is created",
  "type": "object",
  "required": [
    "event_id",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (idempotency key)"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was generated"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant/app identifier for multi-tenant isolation"
    },
    "source_module": {
      "type": "string",
      "const": "party",
      "description": "Module that generated the event"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the source module"
    },
    "correlation_id": {
      "type": "string",
      "description": "Links related events in a business transaction"
    },
    "causation_id": {
      "type": "string",
      "description": "Links this event to the command/event that caused it"
    },
    "payload": {
      "type": "object",
      "required": [
        "party_id",
        "app_id",
        "party_type",
        "display_name",
        "created_at"
      ],
      "properties": {
        "party_id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the created party"
        },
        "app_id": {
          "type": "string",
          "description": "Application/tenant identifier"
        },
        "party_type": {
          "type": "string",
          "enum": ["company", "individual"],
          "description": "Type of party created"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name of the party"
        },
        "email": {
          "type": ["string", "null"],
          "description": "Contact email for the party"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the party was created"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
