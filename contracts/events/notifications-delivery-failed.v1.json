{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/notifications-delivery-failed.v1.json",
  "title": "notifications.delivery.failed",
  "description": "Event emitted when notification delivery fails",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "const": "notifications.delivery.failed" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "source_module": { "type": "string", "const": "notifications" },
    "source_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "schema_version": { "type": "string", "minLength": 1 },
    "replay_safe": { "type": "boolean" },
    "mutation_class": {
      "type": "string",
      "enum": ["SIDE_EFFECT", "LIFECYCLE", "DATA_MUTATION", "REVERSAL", "CORRECTION", "QUERY", "ADMINISTRATIVE"]
    },
    "correlation_id": { "type": "string" },
    "causation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["notification_id", "channel"],
      "properties": {
        "notification_id": { "type": ["string", "object"] },
        "channel": { "type": "string", "minLength": 1 },
        "to": { "type": "string" },
        "template_id": { "type": "string" },
        "template_key": { "type": "string" },
        "status": { "type": "string" },
        "failure_code": { "type": "string" },
        "failure_message": { "type": "string" },
        "attempts": { "type": "integer", "minimum": 1 },
        "attempt_no": { "type": "integer", "minimum": 1 },
        "attempt_status": { "type": "string" },
        "scheduled_status": { "type": "string" },
        "idempotency_key": { "type": "string" },
        "provider_message_id": { "type": ["string", "null"] },
        "error_class": { "type": ["string", "null"] },
        "error_message": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
