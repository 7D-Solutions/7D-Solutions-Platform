{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/ap-po-closed.v1.json",
  "title": "ap.po_closed",
  "description": "Event emitted when a purchase order is closed (fully received, cancelled, or manually closed)",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (idempotency key)"
    },
    "event_type": {
      "type": "string",
      "const": "ap.po_closed",
      "description": "Event type following entity.action convention"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was generated"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant identifier for multi-tenant isolation"
    },
    "source_module": {
      "type": "string",
      "const": "ap",
      "description": "Module that generated the event"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the source module"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "Schema version of the payload"
    },
    "replay_safe": {
      "type": "boolean",
      "description": "Whether the event can be safely replayed"
    },
    "mutation_class": {
      "type": "string",
      "enum": [
        "DATA_MUTATION",
        "REVERSAL",
        "CORRECTION",
        "SIDE_EFFECT",
        "QUERY",
        "LIFECYCLE",
        "ADMINISTRATIVE"
      ],
      "description": "Classification of the mutation"
    },
    "correlation_id": {
      "type": "string",
      "description": "Links related events in a business transaction"
    },
    "causation_id": {
      "type": "string",
      "description": "Links this event to the command/event that caused it"
    },
    "payload": {
      "type": "object",
      "required": [
        "po_id",
        "tenant_id",
        "vendor_id",
        "po_number",
        "close_reason",
        "closed_by",
        "closed_at"
      ],
      "properties": {
        "po_id": {
          "type": "string",
          "format": "uuid",
          "description": "Purchase order identifier"
        },
        "tenant_id": {
          "type": "string",
          "description": "Tenant identifier"
        },
        "vendor_id": {
          "type": "string",
          "format": "uuid",
          "description": "Vendor identifier"
        },
        "po_number": {
          "type": "string",
          "description": "Human-readable PO number"
        },
        "close_reason": {
          "type": "string",
          "enum": [
            "fully_received",
            "cancelled",
            "manual_close"
          ],
          "description": "Reason the PO was closed"
        },
        "closed_by": {
          "type": "string",
          "description": "Actor who closed the PO"
        },
        "closed_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of closure"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
