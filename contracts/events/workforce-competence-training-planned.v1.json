{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/workforce-competence-training-planned.v1.json",
  "title": "workforce_competence.training_planned",
  "description": "Event emitted when a training plan is created in the workforce competence module",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "const": "workforce_competence.training_planned" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string" },
    "source_module": { "type": "string", "const": "workforce_competence" },
    "source_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "schema_version": { "type": "string", "minLength": 1 },
    "replay_safe": { "type": "boolean" },
    "mutation_class": { "type": "string", "enum": ["DATA_MUTATION", "REVERSAL", "CORRECTION", "SIDE_EFFECT", "QUERY", "LIFECYCLE", "ADMINISTRATIVE"] },
    "correlation_id": { "type": ["string", "null"] },
    "causation_id": { "type": ["string", "null"] },
    "payload": {
      "type": "object",
      "required": ["plan_id", "tenant_id", "plan_code", "artifact_id", "title"],
      "properties": {
        "plan_id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string" },
        "plan_code": { "type": "string" },
        "artifact_id": { "type": "string", "format": "uuid" },
        "title": { "type": "string" },
        "scheduled_at": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
