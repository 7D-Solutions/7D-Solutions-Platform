{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/ap-vendor-bill-approved.v1.json",
  "title": "ap.vendor_bill_approved",
  "description": "Event emitted when a vendor bill is approved for payment",
  "type": "object",
  "required": [
    "event_id",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (idempotency key)"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was generated"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant identifier for multi-tenant isolation"
    },
    "source_module": {
      "type": "string",
      "const": "ap",
      "description": "Module that generated the event"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the source module"
    },
    "correlation_id": {
      "type": "string",
      "description": "Links related events in a business transaction"
    },
    "causation_id": {
      "type": "string",
      "description": "Links this event to the command/event that caused it"
    },
    "payload": {
      "type": "object",
      "required": [
        "bill_id",
        "tenant_id",
        "vendor_id",
        "vendor_invoice_ref",
        "approved_amount_minor",
        "currency",
        "due_date",
        "approved_by",
        "approved_at"
      ],
      "properties": {
        "bill_id": {
          "type": "string",
          "format": "uuid",
          "description": "Vendor bill identifier"
        },
        "tenant_id": {
          "type": "string",
          "description": "Tenant identifier"
        },
        "vendor_id": {
          "type": "string",
          "format": "uuid",
          "description": "Vendor identifier"
        },
        "vendor_invoice_ref": {
          "type": "string",
          "description": "Vendor's invoice number (external reference)"
        },
        "approved_amount_minor": {
          "type": "integer",
          "description": "Approved amount in minor currency units"
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3,
          "pattern": "^[A-Z]{3}$",
          "description": "ISO 4217 currency code"
        },
        "due_date": {
          "type": "string",
          "format": "date-time",
          "description": "Payment due date"
        },
        "approved_by": {
          "type": "string",
          "description": "Actor who approved the bill"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of approval"
        },
        "fx_rate_id": {
          "type": ["string", "null"],
          "format": "uuid",
          "description": "FX rate record used at bill entry (null when same currency)"
        },
        "gl_lines": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["line_id", "gl_account_code", "amount_minor"],
            "properties": {
              "line_id": { "type": "string", "format": "uuid" },
              "gl_account_code": { "type": "string" },
              "amount_minor": { "type": "integer" },
              "po_line_id": { "type": ["string", "null"], "format": "uuid" }
            },
            "additionalProperties": false
          },
          "description": "Per-line GL expense account allocations for replay-safe GL posting"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
