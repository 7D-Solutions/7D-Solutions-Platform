{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/outside-processing-shipment-requested.v1.json",
  "title": "outside_processing.shipment_requested",
  "description": "Emitted to notify Shipping-Receiving to create an outbound shipment to vendor",
  "type": "object",
  "required": ["event_id","event_type","occurred_at","tenant_id","source_module","source_version","schema_version","replay_safe","mutation_class","payload"],
  "properties": {
    "event_id": {"type":"string","format":"uuid"},
    "event_type": {"type":"string","const":"outside_processing.shipment_requested"},
    "occurred_at": {"type":"string","format":"date-time"},
    "tenant_id": {"type":"string"},
    "source_module": {"type":"string","const":"outside-processing"},
    "source_version": {"type":"string"},
    "schema_version": {"type":"string"},
    "replay_safe": {"type":"boolean"},
    "mutation_class": {"type":"string"},
    "payload": {
      "type":"object",
      "required":["op_order_id","ship_event_id","tenant_id","quantity_shipped"],
      "properties": {
        "op_order_id": {"type":"string","format":"uuid"},
        "ship_event_id": {"type":"string","format":"uuid"},
        "tenant_id": {"type":"string"},
        "vendor_id": {"type":["string","null"],"format":"uuid"},
        "quantity_shipped": {"type":"integer","minimum":1},
        "lot_number": {"type":["string","null"]},
        "part_number": {"type":["string","null"]}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
