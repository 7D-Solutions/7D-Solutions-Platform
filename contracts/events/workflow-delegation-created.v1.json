{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/workflow-delegation-created.v1.json",
  "title": "delegation.created",
  "description": "Event emitted when an actor delegates their workflow authority to another actor",
  "type": "object",
  "required": [
    "event_id",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (idempotency key)"
    },
    "event_type": {
      "type": "string",
      "const": "delegation.created",
      "description": "Event type following entity.action convention"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was generated"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1,
      "description": "Tenant identifier for multi-tenant isolation"
    },
    "source_module": {
      "type": "string",
      "const": "workflow",
      "description": "Module that generated the event"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the source module"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "Schema version of the payload"
    },
    "replay_safe": {
      "type": "boolean",
      "description": "Whether the event can be safely replayed"
    },
    "mutation_class": {
      "type": "string",
      "enum": ["DATA_MUTATION", "REVERSAL", "CORRECTION", "SIDE_EFFECT", "QUERY", "LIFECYCLE", "ADMINISTRATIVE"],
      "description": "Classification of the mutation"
    },
    "correlation_id": {
      "type": "string",
      "description": "Links related events in a business transaction"
    },
    "causation_id": {
      "type": "string",
      "description": "Links this event to the command/event that caused it"
    },
    "payload": {
      "type": "object",
      "required": [
        "delegation_id",
        "tenant_id",
        "delegator_id",
        "delegatee_id",
        "valid_from"
      ],
      "properties": {
        "delegation_id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique delegation rule identifier"
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1,
          "description": "Tenant identifier (matches envelope tenant_id)"
        },
        "delegator_id": {
          "type": "string",
          "format": "uuid",
          "description": "Actor delegating their authority"
        },
        "delegatee_id": {
          "type": "string",
          "format": "uuid",
          "description": "Actor receiving the delegated authority"
        },
        "definition_id": {
          "type": ["string", "null"],
          "format": "uuid",
          "description": "Workflow definition scope (null = all definitions)"
        },
        "entity_type": {
          "type": ["string", "null"],
          "description": "Entity type scope (null = all entity types)"
        },
        "valid_from": {
          "type": "string",
          "format": "date-time",
          "description": "When the delegation becomes active"
        },
        "valid_until": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When the delegation expires (null = no expiry)"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
