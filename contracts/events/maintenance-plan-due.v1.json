{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/maintenance-plan-due.v1.json",
  "title": "maintenance.plan.due",
  "description": "Event emitted when a maintenance plan assignment becomes due (calendar or meter threshold reached)",
  "type": "object",
  "required": [
    "event_id",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (idempotency key)"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was generated"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant identifier for multi-tenant isolation"
    },
    "source_module": {
      "type": "string",
      "const": "maintenance",
      "description": "Module that generated the event"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the source module"
    },
    "correlation_id": {
      "type": "string",
      "description": "Links related events in a business transaction"
    },
    "causation_id": {
      "type": "string",
      "description": "Links this event to the command/event that caused it"
    },
    "payload": {
      "type": "object",
      "required": [
        "assignment_id",
        "plan_id",
        "asset_id",
        "due_kind",
        "due_value"
      ],
      "properties": {
        "assignment_id": {
          "type": "string",
          "format": "uuid",
          "description": "Plan assignment identifier"
        },
        "plan_id": {
          "type": "string",
          "format": "uuid",
          "description": "Maintenance plan identifier"
        },
        "asset_id": {
          "type": "string",
          "format": "uuid",
          "description": "Maintainable asset identifier"
        },
        "due_kind": {
          "type": "string",
          "enum": ["calendar", "meter"],
          "description": "Which condition triggered the due event"
        },
        "due_value": {
          "type": "string",
          "description": "The due threshold — date string for calendar, meter reading for meter"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
