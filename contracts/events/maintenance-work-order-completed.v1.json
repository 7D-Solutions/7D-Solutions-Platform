{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/maintenance-work-order-completed.v1.json",
  "title": "maintenance.work_order.completed",
  "description": "Event emitted when a work order is completed. Carries cost data for GL integration.",
  "type": "object",
  "required": [
    "event_id",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (idempotency key)"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was generated"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant identifier for multi-tenant isolation"
    },
    "source_module": {
      "type": "string",
      "const": "maintenance",
      "description": "Module that generated the event"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the source module"
    },
    "correlation_id": {
      "type": "string",
      "description": "Links related events in a business transaction"
    },
    "causation_id": {
      "type": "string",
      "description": "Links this event to the command/event that caused it"
    },
    "payload": {
      "type": "object",
      "required": [
        "wo_id",
        "asset_id",
        "total_parts_minor",
        "total_labor_minor",
        "currency",
        "downtime_minutes"
      ],
      "properties": {
        "wo_id": {
          "type": "string",
          "format": "uuid",
          "description": "Work order identifier"
        },
        "asset_id": {
          "type": "string",
          "format": "uuid",
          "description": "Maintainable asset identifier"
        },
        "total_parts_minor": {
          "type": "integer",
          "format": "int64",
          "minimum": 0,
          "description": "Total parts cost in minor currency units"
        },
        "total_labor_minor": {
          "type": "integer",
          "format": "int64",
          "minimum": 0,
          "description": "Total labor cost in minor currency units"
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "ISO 4217 currency code"
        },
        "downtime_minutes": {
          "type": "integer",
          "minimum": 0,
          "description": "Total asset downtime in minutes"
        },
        "fixed_asset_ref": {
          "type": "string",
          "format": "uuid",
          "description": "Optional Fixed-Assets reference for GL correlation"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
