{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/workforce-competence-training-completed.v1.json",
  "title": "workforce_competence.training_completed",
  "description": "Event emitted when a training completion is recorded. When outcome=passed, resulting_competence_assignment_id is set.",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "const": "workforce_competence.training_completed" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string" },
    "source_module": { "type": "string", "const": "workforce_competence" },
    "source_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "schema_version": { "type": "string", "minLength": 1 },
    "replay_safe": { "type": "boolean" },
    "mutation_class": { "type": "string", "enum": ["DATA_MUTATION", "REVERSAL", "CORRECTION", "SIDE_EFFECT", "QUERY", "LIFECYCLE", "ADMINISTRATIVE"] },
    "correlation_id": { "type": ["string", "null"] },
    "causation_id": { "type": ["string", "null"] },
    "payload": {
      "type": "object",
      "required": [
        "completion_id", "tenant_id", "assignment_id", "operator_id",
        "plan_id", "completed_at", "outcome"
      ],
      "properties": {
        "completion_id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string" },
        "assignment_id": { "type": "string", "format": "uuid" },
        "operator_id": { "type": "string", "format": "uuid" },
        "plan_id": { "type": "string", "format": "uuid" },
        "completed_at": { "type": "string", "format": "date-time" },
        "outcome": { "type": "string", "enum": ["passed", "failed", "incomplete"] },
        "resulting_competence_assignment_id": { "type": ["string", "null"], "format": "uuid" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
