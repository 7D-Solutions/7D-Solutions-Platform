{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/ap-vendor-bill-matched.v1.json",
  "title": "ap.vendor_bill_matched",
  "description": "Event emitted when a vendor bill is matched to PO lines (2-way or 3-way match)",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (idempotency key)"
    },
    "event_type": {
      "type": "string",
      "const": "ap.vendor_bill_matched",
      "description": "Event type following entity.action convention"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was generated"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant identifier for multi-tenant isolation"
    },
    "source_module": {
      "type": "string",
      "const": "ap",
      "description": "Module that generated the event"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the source module"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "Schema version of the payload"
    },
    "replay_safe": {
      "type": "boolean",
      "description": "Whether the event can be safely replayed"
    },
    "mutation_class": {
      "type": "string",
      "enum": [
        "DATA_MUTATION",
        "REVERSAL",
        "CORRECTION",
        "SIDE_EFFECT",
        "QUERY",
        "LIFECYCLE",
        "ADMINISTRATIVE"
      ],
      "description": "Classification of the mutation"
    },
    "correlation_id": {
      "type": "string",
      "description": "Links related events in a business transaction"
    },
    "causation_id": {
      "type": "string",
      "description": "Links this event to the command/event that caused it"
    },
    "payload": {
      "type": "object",
      "required": [
        "bill_id",
        "tenant_id",
        "vendor_id",
        "po_id",
        "match_type",
        "match_lines",
        "fully_matched",
        "matched_by",
        "matched_at"
      ],
      "properties": {
        "bill_id": {
          "type": "string",
          "format": "uuid",
          "description": "Vendor bill identifier"
        },
        "tenant_id": {
          "type": "string",
          "description": "Tenant identifier"
        },
        "vendor_id": {
          "type": "string",
          "format": "uuid",
          "description": "Vendor identifier"
        },
        "po_id": {
          "type": "string",
          "format": "uuid",
          "description": "Purchase order matched against"
        },
        "match_type": {
          "type": "string",
          "enum": [
            "two_way",
            "three_way",
            "non_po"
          ],
          "description": "Type of PO match performed"
        },
        "match_lines": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "bill_line_id",
              "po_line_id",
              "matched_quantity",
              "matched_amount_minor",
              "within_tolerance"
            ],
            "properties": {
              "bill_line_id": {
                "type": "string",
                "format": "uuid"
              },
              "po_line_id": {
                "type": "string",
                "format": "uuid"
              },
              "receipt_id": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "uuid"
              },
              "matched_quantity": {
                "type": "number"
              },
              "matched_amount_minor": {
                "type": "integer"
              },
              "within_tolerance": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          },
          "minItems": 1
        },
        "fully_matched": {
          "type": "boolean",
          "description": "True if all lines matched within tolerance"
        },
        "matched_by": {
          "type": "string",
          "description": "Actor who performed the match"
        },
        "matched_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of match"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
