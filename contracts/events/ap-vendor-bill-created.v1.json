{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/ap-vendor-bill-created.v1.json",
  "title": "ap.vendor_bill_created",
  "description": "Event emitted when a vendor invoice/bill is entered into AP",
  "type": "object",
  "required": [
    "event_id",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (idempotency key)"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was generated"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant identifier for multi-tenant isolation"
    },
    "source_module": {
      "type": "string",
      "const": "ap",
      "description": "Module that generated the event"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the source module"
    },
    "correlation_id": {
      "type": "string",
      "description": "Links related events in a business transaction"
    },
    "causation_id": {
      "type": "string",
      "description": "Links this event to the command/event that caused it"
    },
    "payload": {
      "type": "object",
      "required": [
        "bill_id",
        "tenant_id",
        "vendor_id",
        "vendor_invoice_ref",
        "currency",
        "lines",
        "total_minor",
        "invoice_date",
        "due_date",
        "entered_by",
        "entered_at"
      ],
      "properties": {
        "bill_id": {
          "type": "string",
          "format": "uuid",
          "description": "Vendor bill identifier"
        },
        "tenant_id": {
          "type": "string",
          "description": "Tenant identifier"
        },
        "vendor_id": {
          "type": "string",
          "format": "uuid",
          "description": "Vendor identifier"
        },
        "vendor_invoice_ref": {
          "type": "string",
          "description": "Vendor's invoice number (external reference)"
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3,
          "pattern": "^[A-Z]{3}$",
          "description": "ISO 4217 currency code"
        },
        "lines": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["line_id", "description", "quantity", "unit_price_minor", "line_total_minor", "gl_account_code"],
            "properties": {
              "line_id": { "type": "string", "format": "uuid" },
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "unit_price_minor": { "type": "integer" },
              "line_total_minor": { "type": "integer" },
              "gl_account_code": { "type": "string" },
              "po_line_id": { "type": ["string", "null"], "format": "uuid" }
            },
            "additionalProperties": false
          },
          "minItems": 1
        },
        "total_minor": {
          "type": "integer",
          "description": "Total bill amount in minor currency units"
        },
        "tax_minor": {
          "type": ["integer", "null"],
          "description": "Tax amount in minor currency units (null if not itemized)"
        },
        "invoice_date": {
          "type": "string",
          "format": "date-time",
          "description": "Invoice date"
        },
        "due_date": {
          "type": "string",
          "format": "date-time",
          "description": "Payment due date"
        },
        "entered_by": {
          "type": "string",
          "description": "Actor who entered the bill"
        },
        "entered_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of entry"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
