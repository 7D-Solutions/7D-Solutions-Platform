{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/crm-pipeline-activity-logged.v1.json",
  "title": "crm_pipeline.activity_logged",
  "description": "Event emitted when a CRM activity is logged",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "const": "crm_pipeline.activity_logged" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string" },
    "source_module": { "type": "string", "const": "crm-pipeline" },
    "source_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "schema_version": { "type": "string", "minLength": 1 },
    "replay_safe": { "type": "boolean" },
    "mutation_class": { "type": "string", "enum": ["DATA_MUTATION", "REVERSAL", "CORRECTION", "SIDE_EFFECT", "QUERY", "LIFECYCLE", "ADMINISTRATIVE"] },
    "correlation_id": { "type": "string" },
    "causation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["activity_id", "tenant_id", "activity_type_code", "entity_type", "entity_id"],
      "properties": {
        "activity_id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string" },
        "activity_type_code": { "type": "string" },
        "entity_type": { "type": "string" },
        "entity_id": { "type": "string", "format": "uuid" },
        "assigned_to": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
