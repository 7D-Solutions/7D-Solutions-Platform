{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/integrations-external-ref-deleted.v1.json",
  "title": "external_ref.deleted",
  "description": "Event emitted when an external reference mapping is deleted",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "const": "external_ref.deleted" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "source_module": { "type": "string", "const": "integrations" },
    "source_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "schema_version": { "type": "string", "minLength": 1 },
    "replay_safe": { "type": "boolean" },
    "mutation_class": { "type": "string", "const": "LIFECYCLE" },
    "correlation_id": { "type": "string" },
    "causation_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": [
        "ref_id",
        "app_id",
        "entity_type",
        "entity_id",
        "system",
        "external_id",
        "deleted_at"
      ],
      "properties": {
        "ref_id": { "type": "integer" },
        "app_id": { "type": "string", "minLength": 1 },
        "entity_type": { "type": "string", "minLength": 1 },
        "entity_id": { "type": "string", "minLength": 1 },
        "system": { "type": "string", "minLength": 1 },
        "external_id": { "type": "string", "minLength": 1 },
        "deleted_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
