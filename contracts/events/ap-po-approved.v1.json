{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/ap-po-approved.v1.json",
  "title": "ap.po_approved",
  "description": "Event emitted when a purchase order is approved for fulfillment",
  "type": "object",
  "required": [
    "event_id",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (idempotency key)"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was generated"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant identifier for multi-tenant isolation"
    },
    "source_module": {
      "type": "string",
      "const": "ap",
      "description": "Module that generated the event"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the source module"
    },
    "correlation_id": {
      "type": "string",
      "description": "Links related events in a business transaction"
    },
    "causation_id": {
      "type": "string",
      "description": "Links this event to the command/event that caused it"
    },
    "payload": {
      "type": "object",
      "required": [
        "po_id",
        "tenant_id",
        "vendor_id",
        "po_number",
        "approved_amount_minor",
        "currency",
        "approved_by",
        "approved_at"
      ],
      "properties": {
        "po_id": {
          "type": "string",
          "format": "uuid",
          "description": "Purchase order identifier"
        },
        "tenant_id": {
          "type": "string",
          "description": "Tenant identifier"
        },
        "vendor_id": {
          "type": "string",
          "format": "uuid",
          "description": "Vendor identifier"
        },
        "po_number": {
          "type": "string",
          "description": "Human-readable PO number"
        },
        "approved_amount_minor": {
          "type": "integer",
          "description": "Total approved amount in minor currency units"
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3,
          "pattern": "^[A-Z]{3}$",
          "description": "ISO 4217 currency code"
        },
        "approved_by": {
          "type": "string",
          "description": "Actor who approved the PO"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of approval"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
