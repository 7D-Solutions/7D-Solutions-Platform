{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/customer-complaints-customer-communicated.v1.json",
  "title": "customer_complaints.customer_communicated",
  "description": "Event emitted when a customer-facing communication is logged on a complaint",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "const": "customer_complaints.customer_communicated"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "source_module": {
      "type": "string",
      "const": "customer-complaints"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "replay_safe": {
      "type": "boolean"
    },
    "mutation_class": {
      "type": "string",
      "enum": [
        "DATA_MUTATION",
        "REVERSAL",
        "CORRECTION",
        "SIDE_EFFECT",
        "QUERY",
        "LIFECYCLE",
        "ADMINISTRATIVE"
      ]
    },
    "correlation_id": {
      "type": "string"
    },
    "causation_id": {
      "type": "string"
    },
    "payload": {
      "type": "object",
      "required": [
        "complaint_id",
        "tenant_id",
        "recorded_by",
        "recorded_at"
      ],
      "properties": {
        "complaint_id": {
          "type": "string",
          "format": "uuid",
          "description": "Complaint identifier"
        },
        "tenant_id": {
          "type": "string",
          "description": "Tenant identifier"
        },
        "recorded_by": {
          "type": "string",
          "description": "User who recorded the communication"
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the communication was recorded"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
