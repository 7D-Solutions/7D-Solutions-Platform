{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7dsolutions.io/schemas/events/production-cost-posted.v1.json",
  "title": "production.cost_posted",
  "description": "Event emitted when a direct cost is posted against a work order",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "source_module",
    "source_version",
    "schema_version",
    "replay_safe",
    "mutation_class",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier (idempotency key)"
    },
    "event_type": {
      "type": "string",
      "const": "production.cost_posted",
      "description": "Event type"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "source_module": {
      "type": "string",
      "const": "production"
    },
    "source_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "replay_safe": {
      "type": "boolean"
    },
    "mutation_class": {
      "type": "string",
      "enum": [
        "DATA_MUTATION",
        "REVERSAL",
        "CORRECTION",
        "SIDE_EFFECT",
        "QUERY",
        "LIFECYCLE",
        "ADMINISTRATIVE"
      ]
    },
    "correlation_id": {
      "type": "string"
    },
    "causation_id": {
      "type": "string"
    },
    "payload": {
      "type": "object",
      "required": [
        "posting_id",
        "work_order_id",
        "tenant_id",
        "posting_category",
        "amount_cents",
        "posted_by"
      ],
      "properties": {
        "posting_id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for this cost posting"
        },
        "work_order_id": {
          "type": "string",
          "format": "uuid",
          "description": "Work order the cost is posted against"
        },
        "operation_id": {
          "type": "string",
          "format": "uuid",
          "description": "Operation the cost is attributed to (optional)"
        },
        "tenant_id": {
          "type": "string"
        },
        "posting_category": {
          "type": "string",
          "enum": ["labor", "material", "outside_processing", "scrap", "overhead", "other"],
          "description": "Cost category"
        },
        "amount_cents": {
          "type": "integer",
          "description": "Amount in minor currency units"
        },
        "source_event_id": {
          "type": "string",
          "format": "uuid",
          "description": "Source event that triggered this posting (null for manual)"
        },
        "posted_by": {
          "type": "string",
          "description": "Actor or system that posted the cost"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
