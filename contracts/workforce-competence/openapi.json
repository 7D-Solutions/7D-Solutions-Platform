          {
            "name": "id",
            "in": "path",
            "description": "Authority ID",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RevokeAuthorityRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Authority revoked",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AcceptanceAuthority"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": [
              "WORKFORCE_COMPETENCE_MUTATE"
            ]
          }
        ]
      }
    },
    "/api/workforce-competence/acceptance-authority-check": {
      "get": {
        "tags": [
          "Acceptance Authorities"
