          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": [
              "WORKFORCE_COMPETENCE_READ"
            ]
          }
        ]
      }
    },
