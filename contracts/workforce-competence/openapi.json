{
  "openapi": "3.1.0",
  "info": {
    "title": "Workforce Competence Service",
    "description": "Competence registry: skills, certifications, training records, acceptance authorities, and authorization queries.",
    "license": {
      "name": ""
    },
    "version": "2.1.0"
  },
  "paths": {
    "/api/workforce-competence/acceptance-authorities": {
      "post": {
        "tags": [
          "Acceptance Authorities"
        ],
        "operationId": "post_grant_authority",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GrantAuthorityRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Idempotent replay",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AcceptanceAuthority"
                }
              }
            }
          },
          "201": {
            "description": "Authority granted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AcceptanceAuthority"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": [
              "WORKFORCE_COMPETENCE_MUTATE"
            ]
          }
        ]
      }
    },
    "/api/workforce-competence/acceptance-authorities/{id}/revoke": {
      "post": {
        "tags": [
          "Acceptance Authorities"
        ],
        "operationId": "post_revoke_authority",
