            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "capability_scope",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "at_time",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Authority check result",
            "content": {
              "application/json": {
