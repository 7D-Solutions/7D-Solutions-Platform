{
  "openapi": "3.1.0",
  "info": {
    "title": "Subscriptions Service",
    "description": "Subscription lifecycle management, billing cycles, and usage gating.",
    "license": {
      "name": ""
    },
    "version": "5.0.0"
  },
  "paths": {
    "/api/bill-runs/execute": {
      "post": {
        "tags": [
          "Bill Runs"
        ],
        "summary": "POST /api/bill-runs/execute - Execute billing cycle",
        "operationId": "execute_bill_run",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteBillRunRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Bill run completed (or idempotent replay)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillRunResult"
                }
              }
            }
          },
          "401": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "500": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/api/subscriptions/admin/consistency-check": {
      "post": {
        "tags": [
          "Admin"
        ],
        "operationId": "consistency_check",
        "responses": {
          "200": {
            "description": "Consistency check result"
          },
          "403": {
            "description": "Forbidden — invalid or missing admin token"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/subscriptions/admin/projection-status": {
      "post": {
        "tags": [
          "Admin"
        ],
        "operationId": "projection_status",
        "responses": {
          "200": {
            "description": "Projection status returned"
          },
          "403": {
            "description": "Forbidden — invalid or missing admin token"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/subscriptions/admin/projections": {
      "get": {
        "tags": [
          "Admin"
        ],
        "operationId": "list_projections",
        "responses": {
          "200": {
            "description": "List of all known projections"
          },
          "403": {
            "description": "Forbidden — invalid or missing admin token"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  },
