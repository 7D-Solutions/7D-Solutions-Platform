{
  "openapi": "3.0.3",
  "info": {
    "title": "Platform Client Tenant-Registry Service",
    "version": "1.1.0",
    "description": "Tenant CRUD, lifecycle management, plan tiers, fleet summary, entitlements, and status."
  },
  "paths": {
    "/api/tenants": {
      "get": {
        "operationId": "list_tenants",
        "tags": ["tenants"],
        "summary": "List tenants with optional filters and pagination",
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "plan",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "app_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated tenant list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TenantListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/tenants/{tenant_id}": {
      "get": {
        "operationId": "get_tenant_detail",
        "tags": ["tenants"],
        "summary": "Get tenant detail including seat limit",
        "parameters": [
          {
            "name": "tenant_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Tenant detail",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TenantDetailDto" }
              }
            }
          }
        }
      }
    },
    "/api/tenants/{tenant_id}/entitlements": {
      "get": {
        "operationId": "get_entitlements",
        "tags": ["tenants"],
        "summary": "Get entitlements for a tenant",
        "parameters": [
          {
            "name": "tenant_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Entitlement details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EntitlementRow" }
              }
            }
          }
        }
      }
    },
    "/api/tenants/{tenant_id}/app-id": {
      "get": {
        "operationId": "get_app_id",
        "tags": ["tenants"],
        "summary": "Get the app_id mapping for a tenant",
        "parameters": [
          {
            "name": "tenant_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "App ID mapping",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TenantAppIdRow" }
              }
            }
          }
        }
      }
    },
    "/api/tenants/{tenant_id}/status": {
      "get": {
        "operationId": "get_tenant_status",
        "tags": ["tenants"],
        "summary": "Get lifecycle status for a tenant",
        "parameters": [
          {
            "name": "tenant_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Tenant status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TenantStatusRow" }
              }
            }
          }
        }
      }
    },
    "/api/control/tenants/{tenant_id}/summary": {
      "get": {
        "operationId": "get_tenant_summary",
        "tags": ["control"],
        "summary": "Get tenant summary with module readiness",
        "parameters": [
          {
            "name": "tenant_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Tenant summary with module readiness",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TenantSummary" }
              }
            }
          }
        }
      }
    },
    "/api/ttp/plans": {
      "get": {
        "operationId": "list_plans",
        "tags": ["plans"],
        "summary": "List platform billing plans",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated plan list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlanListResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TenantSummaryDto": {
        "type": "object",
        "required": ["id", "name", "status", "plan", "created_at", "updated_at"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "plan": { "type": "string" },
          "app_id": { "type": ["string", "null"] },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" }
        }
      },
      "TenantListResponse": {
        "type": "object",
        "required": ["tenants", "total", "page", "page_size"],
        "properties": {
          "tenants": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TenantSummaryDto" }
          },
          "total": { "type": "integer", "format": "int64" },
          "page": { "type": "integer", "format": "int64" },
          "page_size": { "type": "integer", "format": "int64" }
        }
      },
      "TenantDetailDto": {
        "type": "object",
        "required": ["id", "name", "status", "plan", "created_at", "updated_at"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "plan": { "type": "string" },
          "app_id": { "type": ["string", "null"] },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" },
          "seat_limit": { "type": ["integer", "null"], "format": "int32" }
        }
      },
      "EntitlementRow": {
        "type": "object",
        "required": ["tenant_id", "plan_code", "concurrent_user_limit"],
        "properties": {
          "tenant_id": { "type": "string", "format": "uuid" },
          "plan_code": { "type": "string" },
          "concurrent_user_limit": { "type": "integer", "format": "int32" }
        }
      },
      "TenantAppIdRow": {
        "type": "object",
        "required": ["tenant_id", "app_id", "product_code"],
        "properties": {
          "tenant_id": { "type": "string", "format": "uuid" },
          "app_id": { "type": "string" },
          "product_code": { "type": "string" }
        }
      },
      "TenantStatusRow": {
        "type": "object",
        "required": ["tenant_id", "status"],
        "properties": {
          "tenant_id": { "type": "string", "format": "uuid" },
          "status": { "type": "string" }
        }
      },
      "TenantSummary": {
        "type": "object",
        "required": ["tenant_id", "status", "environment", "modules"],
        "properties": {
          "tenant_id": { "type": "string", "format": "uuid" },
          "status": { "type": "string" },
          "environment": { "type": "string" },
          "modules": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ModuleReadiness" }
          }
        }
      },
      "ModuleReadiness": {
        "type": "object",
        "required": ["module", "status", "latency_ms"],
        "properties": {
          "module": { "type": "string" },
          "status": { "type": "string" },
          "schema_version": { "type": ["string", "null"] },
          "latency_ms": { "type": "integer", "format": "int64" },
          "error": { "type": ["string", "null"] }
        }
      },
      "PlanSummary": {
        "type": "object",
        "required": ["id", "name", "pricing_model", "included_seats", "metered_dimensions", "status"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "pricing_model": { "type": "string" },
          "included_seats": { "type": "integer", "format": "int32" },
          "metered_dimensions": {
            "type": "array",
            "items": {}
          },
          "status": { "type": "string" }
        }
      },
      "PlanListResponse": {
        "type": "object",
        "required": ["plans", "total", "page", "page_size"],
        "properties": {
          "plans": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PlanSummary" }
          },
          "total": { "type": "integer", "format": "int64" },
          "page": { "type": "integer", "format": "int64" },
          "page_size": { "type": "integer", "format": "int64" }
        }
      }
    }
  }
}
