  "components": {
    "schemas": {
      "AddLineRequest": {
        "type": "object",
        "required": [
          "qty_expected"
        ],
        "properties": {
          "po_id": {
            "type": [
              "string",
              "null"
            ],
            "format": "uuid"
          },
          "po_line_id": {
            "type": [
              "string",
              "null"
            ],
            "format": "uuid"
          },
          "qty_expected": {
            "type": "integer",
            "format": "int64"
          },
          "sku": {
            "type": [
              "string",
              "null"
            ]
          },
          "source_ref_id": {
            "type": [
              "string",
              "null"
            ],
            "format": "uuid"
          },
          "source_ref_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "uom": {
            "type": [
              "string",
              "null"
            ]
          },
          "warehouse_id": {
            "type": [
              "string",
              "null"
            ],
            "format": "uuid"
          }
        }
      },
      "ApiError": {
        "type": "object",
        "description": "Standard API error envelope.\n\n`error` is a machine-readable code (`not_found`, `validation_error`, etc.).\n`message` is human-readable.  `request_id` is populated from the tracing\ncontext already present in request extensions.  `details` carries per-field\nerrors for 422 responses.",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "details": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "$ref": "#/components/schemas/FieldError"
            }
          },
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "request_id": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "CreateShipmentRequest": {
        "type": "object",
        "required": [
          "direction"
        ],
        "properties": {
          "carrier_party_id": {
            "type": [
              "string",
              "null"
            ],
            "format": "uuid"
          },
          "currency": {
            "type": [
              "string",
              "null"
            ]
          },
          "direction": {
            "$ref": "#/components/schemas/Direction"
          },
          "expected_arrival_date": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "freight_cost_minor": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "tracking_number": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "Direction": {
        "type": "string",
        "description": "Shipment direction — determines which state machine applies.",
        "enum": [
          "inbound",
          "outbound"
        ]
      },
      "FieldError": {
        "type": "object",
        "description": "A single field-level validation error.",
        "required": [
          "field",
          "message"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "InspectionRoutingRow": {
        "type": "object",
        "description": "Row returned from inspection_routings table.",
        "required": [
          "id",
          "tenant_id",
          "shipment_id",
          "shipment_line_id",
          "route_decision",
          "routed_at",
          "created_at"
        ],
