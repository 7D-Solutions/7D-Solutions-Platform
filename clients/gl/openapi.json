        "summary": "Handler for GET /api/gl/periods/{period_id}/close-status?tenant_id={tenant_id}",
        "description": "Query the current close status of a period.\nReturns period date range and close lifecycle state.\n\nO(1) query - single row lookup, no unbounded reads.",
        "operationId": "get_close_status",
        "parameters": [
