    "/api/gl/periods/{period_id}/close": {
      "post": {
        "tags": [
          "Period Close"
        ],
        "summary": "Handler for POST /api/gl/periods/{period_id}/close",
        "description": "Atomically close an accounting period.\nIdempotent - if already closed, returns existing close status.\n\nSteps:\n1. Lock period row (FOR UPDATE)\n2. Check if already closed (idempotency)\n3. Run pre-close validation\n4. Create sealed snapshot with hash\n5. Update period with close fields\n\nReturns close status on success, validation report on failure.",
        "operationId": "close_period_handler",
        "parameters": [
          {
            "name": "period_id",
            "in": "path",
            "description": "Accounting period ID",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Period closed"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
