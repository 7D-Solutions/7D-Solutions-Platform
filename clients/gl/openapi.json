    "/api/gl/revrec/recognition-runs": {
      "post": {
        "tags": [
          "Revenue Recognition"
        ],
        "summary": "POST /api/gl/revrec/recognition-runs",
        "description": "Executes a recognition run for a tenant and period.\nFinds all unrecognized schedule lines due for the period (from latest\nschedule versions), posts balanced journal entries, and emits outbox events.\n\nIdempotent: re-running for the same period skips already-recognized lines.",
        "operationId": "run_recognition_handler",
        "responses": {
          "201": {
            "description": "Recognition run executed"
          }
        },
        "security": [
          {
            "bearer": []
          }
