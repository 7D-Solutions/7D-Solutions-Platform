        "summary": "POST /api/gl/revrec/schedules",
        "description": "Generates a recognition schedule for a performance obligation.\nFetches the obligation from DB, generates the schedule deterministically,\nand persists schedule + lines + outbox event atomically.\n\nVersioned: if an obligation already has a schedule, creates a new version\nlinked to the previous schedule.",
        "operationId": "generate_schedule_handler",
        "responses": {
          "201": {
            "description": "Recognition schedule generated"
