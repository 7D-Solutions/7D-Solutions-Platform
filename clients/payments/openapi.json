{
  "components": {
    "schemas": {
      "ApiError": {
        "description": "Standard API error envelope.\n\n`error` is a machine-readable code (`not_found`, `validation_error`, etc.).\n`message` is human-readable.  `request_id` is populated from the tracing\ncontext already present in request extensions.  `details` carries per-field\nerrors for 422 responses.",
        "properties": {
          "details": {
            "items": {
              "$ref": "#/components/schemas/FieldError"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "request_id": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "error",
          "message"
        ],
        "type": "object"
      },
      "CheckoutSessionStatusResponse": {
        "description": "GET /api/payments/checkout-sessions/:id response",
        "properties": {
          "amount": {
            "format": "int64",
            "type": "integer"
          },
          "cancel_url": {
            "description": "URL to redirect after cancelled payment (stored at creation time)",
            "type": [
              "string",
              "null"
            ]
          },
          "currency": {
            "type": "string"
          },
          "invoice_id": {
            "type": "string"
          },
          "payment_intent_id": {
            "type": "string"
          },
          "return_url": {
            "description": "URL to redirect after successful payment (stored at creation time)",
            "type": [
              "string",
              "null"
            ]
          },
          "session_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "tenant_id": {
            "type": "string"
          }
        },
        "required": [
          "session_id",
          "status",
          "payment_intent_id",
          "invoice_id",
          "tenant_id",
          "amount",
          "currency"
        ],
        "type": "object"
      },
      "ConsistencyCheckSchema": {
        "description": "Consistency check result.",
        "properties": {
          "checked_at": {
            "format": "date-time",
            "type": "string"
          },
          "digest": {
            "type": "string"
          },
          "digest_version": {
            "type": "string"
          },
          "order_by": {
            "type": "string"
          },
          "projection_name": {
            "type": "string"
          },
          "row_count": {
            "format": "int64",
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "table_exists": {
            "type": "boolean"
          }
        },
        "required": [
          "projection_name",
          "table_exists",
          "row_count",
          "digest",
          "digest_version",
          "order_by",
          "checked_at",
          "status"
        ],
        "type": "object"
      },
      "CreateCheckoutSessionRequest": {
        "description": "POST /api/payments/checkout-sessions request body",
        "properties": {
          "amount": {
            "description": "Amount in minor currency units (e.g. cents)",
            "format": "int64",
            "type": "integer"
          },
          "cancel_url": {
            "description": "URL to redirect after cancelled payment (optional)",
            "type": [
              "string",
              "null"
            ]
          },
          "currency": {
            "type": "string"
          },
          "idempotency_key": {
            "description": "Optional idempotency key. If omitted, invoice_id is used as the\nnatural key — one checkout session per invoice per tenant.",
            "type": [
              "string",
              "null"
            ]
          },
          "invoice_id": {
            "type": "string"
          },
          "return_url": {
            "description": "URL to redirect after successful payment (optional)",
            "type": [
              "string",
              "null"
            ]
          },
          "tenant_id": {
            "type": "string"
          }
        },
        "required": [
          "invoice_id",
          "tenant_id",
          "amount",
          "currency"
        ],
        "type": "object"
      },
      "CreateCheckoutSessionResponse": {
        "description": "POST /api/payments/checkout-sessions response",
        "properties": {
          "client_secret": {
            "description": "Tilled.js client secret — pass to tilled.js confirmPayment()",
            "type": "string"
          },
          "payment_intent_id": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          }
        },
        "required": [
          "session_id",
          "payment_intent_id",
          "client_secret"
        ],
        "type": "object"
      },
      "CursorStatusSchema": {
        "description": "Cursor status for a single projection/tenant pair.",
        "properties": {
          "events_processed": {
            "format": "int64",
            "type": "integer"
          },
          "last_event_id": {
            "type": "string"
          },
          "last_event_occurred_at": {
            "format": "date-time",
            "type": "string"
          },
          "projection_name": {
            "type": "string"
          },
          "tenant_id": {
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "projection_name",
          "tenant_id",
          "events_processed",
          "last_event_id",
          "last_event_occurred_at",
          "updated_at"
        ],
        "type": "object"
      },
      "DataSource": {
        "description": "Indicates where the data came from",
        "enum": [
          "projection",
          "fallback"
        ],
        "type": "string"
      },
      "FieldError": {
        "description": "A single field-level validation error.",
        "properties": {
          "field": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "field",
          "message"
        ],
        "type": "object"
      },
      "PaginatedResponse_ProjectionSummarySchema": {
        "description": "Generic paginated response envelope.\n\nEvery list endpoint returns this wrapper so consumers get consistent\npagination metadata regardless of the underlying entity type.",
        "properties": {
          "data": {
            "items": {
              "description": "Summary of a single projection in the listing.",
              "properties": {
                "last_updated": {
                  "format": "date-time",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "projection_name": {
                  "type": "string"
                },
                "tenant_count": {
                  "format": "int64",
                  "type": "integer"
                },
                "total_events_processed": {
                  "format": "int64",
                  "type": "integer"
                }
              },
              "required": [
                "projection_name",
                "tenant_count",
                "total_events_processed"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "pagination": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        },
        "required": [
          "data",
          "pagination"
        ],
        "type": "object"
      },
      "PaginationMeta": {
        "description": "Pagination metadata for list endpoints.",
        "properties": {
          "page": {
            "format": "int64",
            "type": "integer"
          },
          "page_size": {
            "format": "int64",
            "type": "integer"
          },
          "total_items": {
            "format": "int64",
            "type": "integer"
          },
          "total_pages": {
            "format": "int64",
            "type": "integer"
          }
        },
        "required": [
          "page",
          "page_size",
          "total_items",
          "total_pages"
        ],
        "type": "object"
      },
      "PaymentResponse": {
        "description": "Payment response",
        "properties": {
          "amount": {
            "format": "int64",
            "type": "integer"
          },
          "data_source": {
            "$ref": "#/components/schemas/DataSource"
          },
          "payment_id": {
            "format": "uuid",
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "tenant_id": {
            "type": "string"
          }
        },
        "required": [
          "payment_id",
          "tenant_id",
          "amount",
          "status",
          "data_source"
        ],
        "type": "object"
      },
      "ProjectionStatusSchema": {
        "description": "Projection status response (may contain multiple tenant cursors).",
        "properties": {
          "cursors": {
            "items": {
              "$ref": "#/components/schemas/CursorStatusSchema"
            },
            "type": "array"
          },
          "projection_name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "projection_name",
          "cursors",
          "status"
        ],
        "type": "object"
      },
      "ProjectionSummarySchema": {
        "description": "Summary of a single projection in the listing.",
        "properties": {
          "last_updated": {
            "format": "date-time",
            "type": [
              "string",
              "null"
            ]
          },
          "projection_name": {
            "type": "string"
          },
          "tenant_count": {
            "format": "int64",
            "type": "integer"
          },
          "total_events_processed": {
            "format": "int64",
            "type": "integer"
          }
        },
        "required": [
          "projection_name",
          "tenant_count",
          "total_events_processed"
        ],
        "type": "object"
      },
      "SessionStatusPollResponse": {
        "description": "GET /api/payments/checkout-sessions/:id/status response (no secrets)",
        "properties": {
          "session_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "session_id",
          "status"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Payment processing: checkout sessions, payment retrieval, and Tilled webhooks.\n\n**Authentication:** Bearer JWT. Tenant identity derived from JWT claims.",
    "license": {
      "name": ""
    },
    "title": "Payments Service",
    "version": "4.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/payments/admin/consistency-check": {
      "post": {
        "operationId": "consistency_check",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConsistencyCheckSchema"
                }
              }
            },
            "description": "Consistency check result"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Forbidden — invalid or missing admin token"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Internal server error"
          }
        },
        "tags": [
          "Admin"
        ]
      }
    },
    "/api/payments/admin/projection-status": {
      "post": {
        "operationId": "projection_status",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectionStatusSchema"
                }
              }
            },
            "description": "Projection cursor status"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Forbidden — invalid or missing admin token"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Internal server error"
          }
        },
        "tags": [
          "Admin"
        ]
      }
    },
    "/api/payments/admin/projections": {
      "get": {
        "operationId": "list_projections",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse_ProjectionSummarySchema"
                }
              }
            },
            "description": "Paginated list of all known projections"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Forbidden — invalid or missing admin token"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Internal server error"
          }
        },
        "tags": [
          "Admin"
        ]
      }
    },
    "/api/payments/checkout-sessions": {
      "post": {
        "operationId": "create_checkout_session",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCheckoutSessionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateCheckoutSessionResponse"
                }
              }
            },
            "description": "Session created"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Invalid request"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Unauthorized"
          },
          "502": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Payment processor error"
          }
        },
        "security": [
          {
            "bearer": [
              "PAYMENTS_MUTATE"
            ]
          }
        ],
        "tags": [
          "Checkout Sessions"
        ]
      }
    },
    "/api/payments/checkout-sessions/{id}": {
      "get": {
        "operationId": "get_checkout_session",
        "parameters": [
          {
            "description": "Checkout session ID",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckoutSessionStatusResponse"
                }
              }
            },
            "description": "Session details"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Unauthorized"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Session not found"
          }
        },
        "security": [
          {
            "bearer": [
              "PAYMENTS_MUTATE"
            ]
          }
        ],
        "tags": [
          "Checkout Sessions"
        ]
      }
    },
    "/api/payments/checkout-sessions/{id}/present": {
      "post": {
        "operationId": "present_checkout_session",
        "parameters": [
          {
            "description": "Checkout session ID",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Session presented (or already in later state)"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Unauthorized"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Session not found"
          }
        },
        "security": [
          {
            "bearer": [
              "PAYMENTS_MUTATE"
            ]
          }
        ],
        "tags": [
          "Checkout Sessions"
        ]
      }
    },
    "/api/payments/checkout-sessions/{id}/status": {
      "get": {
        "operationId": "poll_checkout_session_status",
        "parameters": [
          {
            "description": "Checkout session ID",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionStatusPollResponse"
                }
              }
            },
            "description": "Session status"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Unauthorized"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Session not found"
          }
        },
        "security": [
          {
            "bearer": [
              "PAYMENTS_MUTATE"
            ]
          }
        ],
        "tags": [
          "Checkout Sessions"
        ]
      }
    },
    "/api/payments/payments": {
      "get": {
        "description": "Demonstrates projection fallback pattern:\n1. Check if projection is stale (beyond threshold)\n2. If stale and circuit is closed, attempt HTTP fallback\n3. Otherwise, query projection normally\n\nThis prevents cascading failures when projections fall behind.",
        "operationId": "get_payment",
        "parameters": [
          {
            "description": "Payment ID",
            "in": "query",
            "name": "payment_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            },
            "description": "Payment details"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Unauthorized"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Internal error"
          }
        },
        "security": [
          {
            "bearer": [
              "PAYMENTS_MUTATE"
            ]
          }
        ],
        "summary": "Handler for GET /api/payments/payments",
        "tags": [
          "Payments"
        ]
      }
    },
    "/api/payments/webhook/tilled": {
      "post": {
        "operationId": "tilled_webhook",
        "responses": {
          "200": {
            "description": "Webhook processed"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Invalid JSON body"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Invalid signature"
          }
        },
        "tags": [
          "Webhooks"
        ]
      }
    },
    "/api/ready": {
      "get": {
        "operationId": "ready",
        "responses": {
          "200": {
            "description": "All dependency checks passed — service is ready"
          },
          "503": {
            "description": "One or more dependency checks failed"
          }
        },
        "summary": "GET /api/ready — readiness probe (verifies DB connectivity)",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/version": {
      "get": {
        "description": "This endpoint provides build and deployment information:\n- module_name: The service identifier\n- module_version: Build version from Cargo.toml\n- schema_version: Database schema version (latest migration)\n\nUsed for:\n- Deployment verification\n- Troubleshooting version mismatches\n- Migration status checks",
        "operationId": "version",
        "responses": {
          "200": {
            "description": "Module name, version, and schema version"
          }
        },
        "summary": "Version endpoint - returns module identity and schema version",
        "tags": [
          "Health"
        ]
      }
    },
    "/healthz": {
      "get": {
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Liveness check — service process is up"
          }
        },
        "summary": "Health check endpoint - returns basic service status (legacy, kept for compat)",
        "tags": [
          "Health"
        ]
      }
    }
  },
  "security": [
    {
      "bearer": []
    }
  ]
}
