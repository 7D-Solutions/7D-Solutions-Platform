          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "All Services Uptime (1 = UP, 0 = DOWN)",
      "description": "Any line dropping to 0 indicates a service outage. See docs/OPS-TRIAGE.md#service-down for response steps.",
