      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(http_requests_total{job=\"payments\",status=~\"5..\"}[5m])",
          "legendFormat": "Payments 5xx",
          "refId": "A"
        }
