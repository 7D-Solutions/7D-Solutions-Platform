        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Webhook Delivery Successes (5m)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(ar_webhook_delivery_successes_total[5m])",
          "legendFormat": "AR Successes",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(payments_webhook_delivery_successes_total[5m])",
          "legendFormat": "Payments Successes",
          "refId": "B"
        }
