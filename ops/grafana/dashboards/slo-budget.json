      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 12 },
              { "color": "red",    "value": 36 }
            ]
          },
          "unit": "short",
          "decimals": 1
