    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Release Freeze Signal",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Release status based on the lowest error budget remaining across all modules. FREEZE RECOMMENDED when any module drops below 10%.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": -1e10,
                "to": 0.05,
                "result": { "color": "dark-red", "index": 0, "text": "RELEASE FREEZE" }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0.05,
                "to": 0.10,
                "result": { "color": "red", "index": 1, "text": "FREEZE RECOMMENDED" }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0.10,
                "to": 0.25,
                "result": { "color": "orange", "index": 2, "text": "BUDGET CRITICAL" }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0.25,
                "to": 1e10,
                "result": { "color": "green", "index": 3, "text": "OK TO RELEASE" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-red", "value": null },
              { "color": "red",      "value": 0.05 },
              { "color": "orange",   "value": 0.10 },
              { "color": "green",    "value": 0.25 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Release Status",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "slo:min_availability_error_budget_remaining:ratio",
          "instant": true,
          "legendFormat": ""
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Lowest availability error budget remaining across all modules. Below 10% triggers a release freeze recommendation.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-red", "value": null },
              { "color": "red",      "value": 0.05 },
              { "color": "orange",   "value": 0.10 },
              { "color": "yellow",   "value": 0.25 },
              { "color": "green",    "value": 0.50 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
