# =========================
# AUTH SERVICE
# =========================
# Ed25519 key pair for JWT signing. Generate with:
#   openssl genpkey -algorithm ed25519 -out private.pem
#   openssl pkey -in private.pem -pubout -out public.pem
# Then paste the full PEM including header/footer lines.
JWT_PRIVATE_KEY_PEM=CHANGE_ME_paste_private_key_pem_here
JWT_PUBLIC_KEY_PEM=CHANGE_ME_paste_public_key_pem_here
JWT_KID=staging-key-1

# =========================
# TCP UI (FRONTEND BFF)
# =========================
# Random 32+ byte secret for BFF session encryption. Generate with:
#   openssl rand -hex 32
JWT_SECRET=CHANGE_ME_random_32_byte_hex

# =========================
# LOGGING
# =========================
RUST_LOG=info
