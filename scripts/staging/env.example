# 7D Solutions Platform — Staging Environment Variables
# Copy this file to .env.staging and populate all values before deploying.
#
# NEVER commit .env.staging to git. It is listed in .gitignore.
# Secret injection: store secrets in your VPS secret manager or pass via
# environment before running deploy_compose.sh.

# =========================
# STAGING VPS
# =========================
# The public hostname or IP of your staging VPS.
STAGING_HOST=staging.7dsolutions.example.com
# SSH user with sudo access on the VPS.
STAGING_USER=deploy
# Path on the VPS where the repo is checked out.
STAGING_REPO_PATH=/opt/7d-platform

# =========================
# AUTH DATABASE
# =========================
AUTH_POSTGRES_DB=auth_db
AUTH_POSTGRES_USER=auth_user
AUTH_POSTGRES_PASSWORD=CHANGE_ME_strong_password

# =========================
# AR DATABASE
# =========================
AR_POSTGRES_DB=ar_db
AR_POSTGRES_USER=ar_user
AR_POSTGRES_PASSWORD=CHANGE_ME_strong_password

