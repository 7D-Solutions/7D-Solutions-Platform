# 7D Solutions Platform — Production Provisioning Variables
# Copy this file to .env.production and populate before provisioning.
#
# NEVER commit .env.production to git. It is listed in .gitignore.
# Application secrets (DB passwords, JWT keys) are managed in the next step:
#   see docs/DEPLOYMENT-PRODUCTION.md → "Environment Contract"

# =========================
# PRODUCTION VPS
# =========================
# Public hostname or IP of your production VPS.
PROD_HOST=prod.7dsolutions.example.com
# SSH port (default 22; change after provisioning if desired).
PROD_SSH_PORT=22
# The initial SSH user for first-time access (root, ubuntu, centos, etc.)
# Used only during Step 3 (deploy user creation). Locked out afterwards.
PROD_INITIAL_USER=root
# The non-root deploy user to create on the VPS.
PROD_DEPLOY_USER=deploy
# Local path to the SSH public key to install for PROD_DEPLOY_USER.
PROD_DEPLOY_KEY="${HOME}/.ssh/id_ed25519.pub"
# Path on the VPS where the repo will be checked out.
PROD_REPO_PATH=/opt/7d-platform
