# Proof runbook test environment overrides.
# Copy to .env.test.proofs and source before running scripts/proofs_runbook.sh.

# Defaults embedded in scripts/proofs_runbook.sh are already correct for local docker-compose.
# Set these only if your ports/credentials differ.

export DATABASE_URL_GL="postgres://gl_user:gl_pass@localhost:5438/gl_db"
export DATABASE_URL_INVENTORY="postgres://inventory_user:inventory_pass@localhost:5442/inventory_db"
export DATABASE_URL_SHIPPING_RECEIVING="postgres://shipping_receiving_user:shipping_receiving_pass@localhost:5454/shipping_receiving_db"
export DATABASE_URL_AUTH="postgres://auth_user:auth_pass@localhost:5433/auth_db"
export DATABASE_URL_TREASURY="postgres://treasury_user:treasury_pass@localhost:5444/treasury_db"

# Auth + treasury integration tests are DB-heavy; run single-threaded to avoid pool timeout cascades.
export RUST_TEST_THREADS_AUTH=1
# Treasury integration tests are DB-heavy; keep single-threaded to avoid pool timeout cascades.
export RUST_TEST_THREADS_TREASURY=1
