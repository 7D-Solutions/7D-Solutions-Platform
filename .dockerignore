target-slot-2/

# Each module's local target dir (in case any exist)
modules/*/target/
platform/*/target/
tools/*/target/
e2e-tests/target/
products/*/target/
products/*/*/target/

# =============================================================================
# Git & CI
# =============================================================================
.git/
.github/

# =============================================================================
# Node / JS
# =============================================================================
node_modules/
package-lock.json

# =============================================================================
