# tenantctl required environment variables
# Copy to .env and fill in real values before running tenantctl.

# Module database passwords (all required)
AR_DB_PASSWORD=
PAYMENTS_DB_PASSWORD=
SUBSCRIPTIONS_DB_PASSWORD=
GL_DB_PASSWORD=
NOTIFICATIONS_DB_PASSWORD=

# Used by lifecycle commands (suspend, deprovision, demo-reset)
PLATFORM_AUDIT_DATABASE_URL=postgres://audit_user:PASSWORD@localhost:5440/audit
TENANT_REGISTRY_DATABASE_URL=postgres://registry_user:PASSWORD@localhost:5441/registry
