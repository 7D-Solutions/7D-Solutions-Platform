  "components": {
    "schemas": {
      "ApiError": {
        "type": "object",
        "description": "Standard API error envelope.\n\n`error` is a machine-readable code (`not_found`, `validation_error`, etc.).\n`message` is human-readable.  `request_id` is populated from the tracing\ncontext already present in request extensions.  `details` carries per-field\nerrors for 422 responses.",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "details": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "$ref": "#/components/schemas/FieldError"
            }
          },
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "request_id": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "AutosaveRequest": {
        "type": "object",
        "required": [
          "field_data"
        ],
        "properties": {
          "field_data": {}
        }
      },
      "CreateFieldRequest": {
        "type": "object",
        "required": [
          "field_key",
          "field_label",
          "field_type"
        ],
        "properties": {
          "field_key": {
            "type": "string"
          },
          "field_label": {
            "type": "string"
          },
          "field_type": {
            "type": "string"
          },
          "pdf_position": {},
          "validation_rules": {}
        }
      },
      "CreateSubmissionRequest": {
        "type": "object",
        "required": [
          "tenant_id",
          "template_id",
          "submitted_by"
        ],
        "properties": {
          "field_data": {},
          "submitted_by": {
            "type": "string"
          },
          "template_id": {
            "type": "string",
            "format": "uuid"
          },
          "tenant_id": {
            "type": "string"
          }
        }
      },
      "CreateTemplateRequest": {
        "type": "object",
        "required": [
          "tenant_id",
          "name",
          "created_by"
        ],
        "properties": {
          "created_by": {
            "type": "string"
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "name": {
            "type": "string"
          },
          "tenant_id": {
            "type": "string"
          }
        }
      },
      "FieldError": {
        "type": "object",
        "description": "A single field-level validation error.",
        "required": [
          "field",
          "message"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "FormField": {
        "type": "object",
        "required": [
          "id",
          "template_id",
          "field_key",
          "field_label",
          "field_type",
          "validation_rules",
          "pdf_position",
          "display_order"
        ],
        "properties": {
          "display_order": {
            "type": "integer",
            "format": "int32"
          },
          "field_key": {
            "type": "string"
          },
          "field_label": {
            "type": "string"
          },
          "field_type": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "pdf_position": {},
          "template_id": {
            "type": "string",
            "format": "uuid"
          },
          "validation_rules": {}
        }
